@model OfficeTaskManagement.Models.UserStory

@{
    ViewData["Title"] = "Delete User Story";
}

<div class="container mt-4">
    <h1 class="text-danger"><i class="fas fa-exclamation-triangle"></i> Delete User Story</h1>
    <p class="lead text-muted">Are you sure you want to delete this user story? This action cannot be undone.</p>

    <div class="card border-danger shadow-sm mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">User Story Confirmation</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Title)</dt>
                <dd class="col-sm-9">@Model.Title</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Feature)</dt>
                <dd class="col-sm-9">@(Model.Feature?.Name ?? "None")</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Created By</dt>
                <dd class="col-sm-9">@Model.CreatedBy?.FullName</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete Permanently</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel and Go Back</a>
    </form>
</div>
