@model IEnumerable<OfficeTaskManagement.Models.UserStory>

@{
    ViewData["Title"] = "User Stories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-book text-primary"></i> User Stories</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Create New
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Title)</th>
                    <th>@Html.DisplayNameFor(model => model.Feature)</th>
                    <th>@Html.DisplayNameFor(model => model.Priority)</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model) {
                <tr>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none">@item.Title</a>
                    </td>
                    <td>@(item.Feature?.Name ?? "None")</td>
                    <td>@item.Priority</td>
                    <td>@item.CreatedBy?.FullName</td>
                    <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="fas fa-edit"></i></a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1"><i class="fas fa-eye"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
</div>
