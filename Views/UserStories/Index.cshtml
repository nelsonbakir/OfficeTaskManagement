@model IEnumerable<OfficeTaskManagement.Models.UserStory>

@{
    ViewData["Title"] = "User Stories";
}

<style>
    .filter-section {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
        border: 1px solid #dee2e6;
    }
    .project-header {
        background: #e9ecef;
        padding: 0.75rem 1.25rem;
        margin-top: 2rem;
        margin-bottom: 1rem;
        border-radius: 6px;
        border-left: 5px solid #0078D4;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .project-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        color: #212529;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-book text-primary"></i> User Stories</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Create New
    </a>
</div>

<div class="filter-section">
    <form asp-action="Index" method="get" class="row align-items-end g-3">
        <div class="col-md-3">
            <label class="form-label fw-bold small text-uppercase">Project</label>
            <select name="projectId" class="form-select" asp-items="ViewBag.ProjectId" onchange="this.form.submit()">
                <option value="">-- All Projects --</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold small text-uppercase">Epic</label>
            <select name="epicId" class="form-select" asp-items="ViewBag.EpicId" onchange="this.form.submit()">
                <option value="">-- All Epics --</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold small text-uppercase">Feature</label>
            <select name="featureId" class="form-select" asp-items="ViewBag.FeatureId">
                <option value="">-- All Features --</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-outline-primary w-100">
                <i class="fas fa-filter"></i> Apply
            </button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </form>
</div>

@if (Model.Any()) {
    var groupedByProject = Model.GroupBy(u => u.Feature?.Epic?.Project?.Name ?? "Unassigned Projects");
    
    foreach (var projectGroup in groupedByProject) {
        <div class="project-header">
            <div>
                <i class="fas fa-folder-open text-primary me-2"></i>
                <h2 class="d-inline-block">@projectGroup.Key</h2>
            </div>
            <span class="badge bg-primary rounded-pill">@projectGroup.Count() Stories</span>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Title</th>
                            <th>Feature / Epic</th>
                            <th>Priority</th>
                            <th>Created By</th>
                            <th>Created At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in projectGroup) {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none">@item.Title</a>
                                </td>
                                <td>
                                    <div class="small">
                                        <i class="fas fa-cube text-muted me-1"></i> @(item.Feature?.Name ?? "N/A")
                                    </div>
                                    <div class="text-muted" style="font-size: 11px;">
                                        <i class="fas fa-layer-group me-1"></i> @(item.Feature?.Epic?.Name ?? "N/A")
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var priorityClass = item.Priority switch {
                                            OfficeTaskManagement.Models.Enums.TaskPriority.High => "badge bg-danger",
                                            OfficeTaskManagement.Models.Enums.TaskPriority.Medium => "badge bg-warning text-dark",
                                            _ => "badge bg-info"
                                        };
                                    }
                                    <span class="@priorityClass">@item.Priority</span>
                                </td>
                                <td>@item.CreatedBy?.FullName</td>
                                <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
} else {
    <div class="text-center py-5">
        <i class="fas fa-search fa-3x text-muted mb-3"></i>
        <h3>No user stories found</h3>
        <p class="text-muted">Try adjusting your filters or create a new story.</p>
        <a asp-action="Create" class="btn btn-primary mt-2">Create New Story</a>
    </div>
}
