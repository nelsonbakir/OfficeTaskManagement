@model OfficeTaskManagement.ViewModels.ResourceManagement.ResourceProfileViewModel

@{
    ViewData["Title"] = $"Profile: {Model.FullName}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-badge"></i> @Model.FullName's Resource Profile</h2>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Pool</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <!-- Left Column: Edit Form -->
    <div class="col-md-5 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">Profile Settings</h5>
            </div>
            <div class="card-body">
                <form asp-action="Profile" method="post">
                    <input type="hidden" asp-for="UserId" />
                    
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-muted"></label>
                        <input asp-for="Email" class="form-control" disabled />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label"></label>
                            <input asp-for="Department" class="form-control" placeholder="e.g., Engineering" />
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SeniorityLevel" class="form-label"></label>
                            <select asp-for="SeniorityLevel" asp-items="Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.SeniorityLevel>()" class="form-select"></select>
                            <span asp-validation-for="SeniorityLevel" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="DailyCapacityHours" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="DailyCapacityHours" class="form-control" type="number" step="0.5" min="0.5" max="24" />
                                <span class="input-group-text">hrs</span>
                            </div>
                            <span asp-validation-for="DailyCapacityHours" class="text-danger"></span>
                            <div class="form-text">Standard working capacity per day.</div>
                        </div>
                        
                        @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
                        {
                            <div class="col-md-6">
                                <label asp-for="HourlyRate" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="HourlyRate" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="HourlyRate" class="text-danger"></span>
                                <div class="form-text text-warning"><i class="bi bi-lock-fill"></i> Manager view only.</div>
                            </div>
                        }
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Working preferences, timezone constraints, etc."></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
                    {
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">Save Profile</button>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">Only managers can update resource settings.</div>
                    }
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Context Information -->
    <div class="col-md-7 mb-4">
        
        <!-- Status Card -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h6 class="text-uppercase text-muted mb-3">Current Month Utilization</h6>
                @{
                    var utilClass = Model.UtilizationPercent > 100 ? "bg-danger" : (Model.UtilizationPercent >= 80 ? "bg-warning" : "bg-success");
                }
                <div class="d-flex align-items-center mb-2">
                    <h2 class="mb-0 me-3">@Model.UtilizationPercent%</h2>
                    @if (Model.IsOverAllocated)
                    {
                        <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-exclamation-triangle-fill"></i> Over-Allocated</span>
                    }
                </div>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar @utilClass" role="progressbar" style="width: @Math.Min(100, Model.UtilizationPercent)%;"></div>
                </div>
            </div>
        </div>

        <!-- Active Allocations -->
        <div class="card shadow-sm mb-4 border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Active Project Allocations</h6>
                <span class="badge bg-light text-primary">@Model.ActiveAllocations.Count Active</span>
            </div>
            <div class="card-body p-0">
                @if (Model.ActiveAllocations.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var alloc in Model.ActiveAllocations)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong><a asp-controller="Projects" asp-action="Details" asp-route-id="@alloc.ProjectId">@alloc.ProjectName</a></strong>
                                    <br />
                                    <small class="text-muted">Role: @(alloc.ProjectRole ?? "Team Member")</small>
                                    <br />
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3"></i> @alloc.StartDate.ToShortDateString() - @(alloc.EndDate?.ToShortDateString() ?? "Ongoing")
                                    </small>
                                </div>
                                <span class="badge bg-primary rounded-pill" style="font-size: 1.1em;">@alloc.AllocationPercentage%</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-folder-x fs-2"></i>
                        <p class="mt-2">No active project allocations.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Skills -->
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Skills Portfolio</h6>
                @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
                {
                    <button class="btn btn-sm btn-outline-primary"><i class="bi bi-plus"></i> Add Skill</button>
                }
            </div>
            <div class="card-body">
                @if (Model.Skills.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var skill in Model.Skills)
                        {
                            var badgeClass = skill.ProficiencyLevel == OfficeTaskManagement.Models.Enums.ProficiencyLevel.Expert ? "bg-dark" :
                                           (skill.ProficiencyLevel == OfficeTaskManagement.Models.Enums.ProficiencyLevel.Intermediate ? "bg-secondary" : "bg-light text-dark border");
                            
                            <span class="badge @badgeClass p-2 px-3">
                                @skill.SkillName <small class="fw-normal ms-1 opacity-75">(@skill.ProficiencyLevel)</small>
                            </span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0 offset-1">No skills configured for this resource.</p>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
