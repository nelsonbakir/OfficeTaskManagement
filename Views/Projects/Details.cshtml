@model OfficeTaskManagement.Models.Project
@{ ViewData["Title"] = "Project Details"; }
<h1>Details</h1>
<div>
    <h4>Project</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>
        <dt class="col-sm-2">Created By</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.CreatedBy.Email)</dd>
    </dl>
</div>
<div>
    @if(User.IsInRole("Manager") || User.IsInRole("Project Lead")) {
        <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> <span>|</span>
    }
    <a asp-action="Index">Back to List</a>
</div>
