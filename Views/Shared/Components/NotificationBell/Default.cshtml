@model OfficeTaskManagement.ViewComponents.NotificationViewModel

<div class="dropdown me-2 notification-dropdown">
    <a class="topbar-icon-button dropdown-toggle position-relative" href="#" id="navbarDropdownNotification" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fas fa-bell"></i>
        @if (Model.UnreadCount > 0)
        {
            <span class="notification-badge">
                @Model.UnreadCount
            </span>
        }
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow-lg" aria-labelledby="navbarDropdownNotification" style="width: 350px; border: 1px solid #EDEBE9; border-radius: 8px; padding: 0;">
        <li style="background: #F8F8F8; border-bottom: 1px solid #EDEBE9; padding: 0.75rem 1rem; border-radius: 8px 8px 0 0; display: flex; justify-content: space-between; align-items: center;">
            <h6 style="margin: 0; font-size: 0.95rem; font-weight: 600; color: #252424;">Notifications</h6>
            @if (Model.UnreadCount > 0)
            {
                <button class="btn btn-sm btn-link text-primary p-0" style="font-size: 0.8rem; text-decoration: none;" onclick="markAllNotificationsAsRead()">Mark all as read</button>
            }
        </li>
        <li>
            <div style="max-height: 300px; overflow-y: auto;" id="notification-list-container">
                @if (!Model.Notifications.Any())
                {
                    <div style="padding: 1.5rem 1rem; text-align: center; color: #605E5C;">
                        <i class="fas fa-bell-slash text-muted" style="font-size: 1.5rem; margin-bottom: 0.5rem;"></i>
                        <p style="margin: 0; font-size: 0.9rem;">You have no notifications.</p>
                    </div>
                }
                else
                {
                    foreach (var notification in Model.Notifications)
                    {
                        var readBg = notification.IsRead ? "white" : "#F0F6FF";
                        var borderLeft = notification.IsRead ? "3px solid transparent" : "3px solid #0078D4";
                        
                        <a class="dropdown-item notification-item" href="@notification.Link" onclick="markNotificationAsRead(event, @notification.Id, '@notification.Link')" style="padding: 0.75rem 1rem; border-bottom: 1px solid #F3F2F1; background-color: @readBg; border-left: @borderLeft; white-space: normal;">
                            <div style="display: flex; gap: 0.75rem;">
                                <div style="flex-shrink: 0; margin-top: 0.2rem;">
                                    @if (notification.Type == "Mention")
                                    {
                                        <i class="fas fa-at" style="color: #8b5cf6;"></i>
                                    }
                                    else if (notification.Type == "Assignment")
                                    {
                                        <i class="fas fa-user-plus text-primary"></i>
                                    }
                                    else if (notification.Type == "StatusUpdate")
                                    {
                                        <i class="fas fa-exchange-alt text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-info-circle text-secondary"></i>
                                    }
                                </div>
                                <div>
                                    <h6 style="font-size: 0.85rem; font-weight: 600; margin-bottom: 0.2rem; color: #252424;">@notification.Title</h6>
                                    <p style="font-size: 0.8rem; margin-bottom: 0.25rem; color: #605E5C; line-height: 1.3;">@notification.Message</p>
                                    <small style="font-size: 0.7rem; color: #A19F9D;">@notification.CreatedAt.ToLocalTime().ToString("g")</small>
                                </div>
                            </div>
                        </a>
                    }
                }
            </div>
        </li>
    </ul>
</div>

<script>
    function markNotificationAsRead(event, id, link) {
        event.preventDefault();
        fetch(`/api/Notifications/${id}/read`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        }).finally(() => {
            window.location.href = link;
        });
    }

    function markAllNotificationsAsRead() {
        fetch(`/api/Notifications/read-all`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        }).then(() => {
            location.reload();
        });
    }
</script>

<style>
    .notification-item:hover {
        background-color: #F8F8F8 !important;
    }
    .notification-item:active {
        background-color: #EDEBE9 !important;
    }
</style>
