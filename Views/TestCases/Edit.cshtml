@model OfficeTaskManagement.ViewModels.TestCaseViewModel
@using OfficeTaskManagement.Services
@inject IMediaService MediaService

@{
    ViewData["Title"] = "Edit Test Case";
}

<style>
    .attachment-list {
        list-style: none;
        padding: 0;
        margin-top: 1rem;
    }

    .attachment-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem;
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
</style>

<h1>Edit Test Case</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="TestCase.Id" />
                    
                    <div class="mb-3">
                        <label asp-for="TestCase.UserStoryId" class="form-label font-weight-bold">User Story</label>
                        <select asp-for="TestCase.UserStoryId" class="form-select" asp-items="ViewBag.UserStoryId">
                            <option value="">-- Select User Story --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TestCase.Title" class="form-label font-weight-bold"></label>
                        <input asp-for="TestCase.Title" class="form-control" />
                        <span asp-validation-for="TestCase.Title" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TestCase.Steps" class="form-label font-weight-bold"></label>
                        <textarea asp-for="TestCase.Steps" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="TestCase.Steps" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TestCase.ExpectedResult" class="form-label font-weight-bold">Expected Result</label>
                        <textarea asp-for="TestCase.ExpectedResult" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="TestCase.ExpectedResult" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="TestCase.IsAutomated" class="form-check-input" />
                        <label asp-for="TestCase.IsAutomated" class="form-check-label font-weight-bold">Is Automated?</label>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Attachments</label>
                        @if (Model.TestCase.Attachments != null && Model.TestCase.Attachments.Any())
                        {
                            <ul class="attachment-list">
                                @foreach (var attachment in Model.TestCase.Attachments)
                                {
                                    <li class="attachment-item">
                                        <div>
                                            <i class="fas fa-file"></i>
                                            <a href="@MediaService.GetUrl(attachment.FilePath)" target="_blank">@attachment.FileName</a>
                                        </div>
                                        <button type="submit" asp-action="DeleteAttachment" asp-route-id="@attachment.Id" class="btn btn-link text-danger p-0" onclick="return confirm('Are you sure?')">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </li>
                                }
                            </ul>
                        }

                        <div class="mt-3">
                            <label>Add More Attachments</label>
                            <input asp-for="Attachments" type="file" class="form-control" multiple />
                            <span asp-validation-for="Attachments" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
