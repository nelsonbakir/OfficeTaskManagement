@model OfficeTaskManagement.Models.TestCase

@{
    ViewData["Title"] = "Test Case Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-vial text-success"></i> Test Case: @Model.Title</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success me-2"><i class="fas fa-edit"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Back to List</a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">Test Steps</h5>
            </div>
            <div class="card-body">
                <div style="white-space: pre-wrap;">@Model.Steps</div>
            </div>
        </div>

        <div class="card shadow-sm mb-4 border-success">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Expected Result</h5>
            </div>
            <div class="card-body">
                <div style="white-space: pre-wrap;">@Model.ExpectedResult</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">Properties</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small text-uppercase font-weight-bold">User Story</label>
                    <div>
                        @if (Model.UserStory != null) {
                            <a asp-controller="UserStories" asp-action="Details" asp-route-id="@Model.UserStoryId" class="fw-bold text-decoration-none">
                                <i class="fas fa-book"></i> @Model.UserStory.Title
                            </a>
                        } else {
                            <span class="text-muted">None</span>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small text-uppercase font-weight-bold">Automation Status</label>
                    <div class="fw-bold">
                        @if (Model.IsAutomated) {
                            <span class="text-success"><i class="fas fa-check-circle"></i> Automated</span>
                        } else {
                            <span class="text-muted"><i class="fas fa-times-circle"></i> Manual</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
