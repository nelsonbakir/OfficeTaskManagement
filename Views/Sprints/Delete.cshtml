@model OfficeTaskManagement.Models.Sprint
@{ ViewData["Title"] = "Delete Sprint"; }
<h1>Delete</h1>
<h3>Are you sure you want to delete this sprint?</h3>
<div>
    <h4>Sprint</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>
        <dt class="col-sm-2">Project</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Project.Name)</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
