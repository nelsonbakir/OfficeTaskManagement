@model List<OfficeTaskManagement.ViewModels.UserManagement.UserListViewModel>

@{
    ViewData["Title"] = "User Management";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 600;
        margin: 0;
        color: #252424;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: #0078D4; /* Primary standard color */
        margin-bottom: 0.25rem;
    }

    .stat-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: #605E5C;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .stat-card.active .stat-value { color: #107C10; }
    .stat-card.inactive .stat-value { color: #A4262C; }

    .table-wrapper {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

    .table th {
        background: #F8F8F8;
        border-bottom: 2px solid #EDEBE9;
        color: #605E5C;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        padding: 1rem;
    }

    .table td {
        vertical-align: middle;
        padding: 1rem;
        border-top: 1px solid #EDEBE9;
        color: #252424;
    }

    .table tr:hover {
        background-color: #F3F2F1;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        border: 1px solid transparent;
        cursor: pointer;
        background: transparent;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .btn-edit { color: #0078D4; }
    .btn-edit:hover { background: #E5F1FB; border-color: #0078D4; }

    .btn-reset { color: #D18700; }
    .btn-reset:hover { background: #FFF4CE; border-color: #D18700; }

    .btn-toggle { color: #605E5C; }
    .btn-toggle:hover { background: #EDEBE9; border-color: #605E5C; }

    .btn-delete { color: #A4262C; }
    .btn-delete:hover { background: #FDE7E9; border-color: #A4262C; }

    .role-badge {
        display: inline-block;
        padding: 0.25rem 0.6rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        margin: 0.1rem;
        background: #E1DFDD;
        color: #323130;
        border: 1px solid #EDEBE9;
    }

    .role-manager { background: #E5E5EA; border-color: #C8C6C4; }
    .role-lead { background: #E3F2FD; border-color: #BBDEFB; color: #0D47A1; }
    .role-coordinator { background: #E8F5E9; border-color: #C8E6C9; color: #1B5E20; }
    .role-employee { background: #FFF3E0; border-color: #FFE0B2; color: #E65100; }
</style>

<div class="container-fluid px-0">
    <div class="page-header">
        <div>
            <h1><i class="fas fa-users" style="color: #0078D4;"></i> User Management</h1>
            <p class="text-muted mb-0">Manage team members and their roles</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New User
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="stats-grid">
            <div class="stat-card active">
                <div class="stat-value">@Model.Count(u => u.IsActive)</div>
                <div class="stat-label">Active Users</div>
            </div>
            <div class="stat-card inactive">
                <div class="stat-value">@Model.Count(u => !u.IsActive)</div>
                <div class="stat-label">Inactive Users</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@Model.Sum(u => u.TotalTasks ?? 0)</div>
                <div class="stat-label">Total Assigned</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@Model.Sum(u => u.CompletedTasks ?? 0)</div>
                <div class="stat-label">Tasks Completed</div>
            </div>
        </div>

        <div class="table-wrapper">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>User Info</th>
                            <th>Roles</th>
                            <th>Status</th>
                            <th>Tasks</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr class="@(!user.IsActive ? "opacity-50 bg-light" : "")">
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width: 40px; height: 40px; border-radius: 50%; background: #0078D4; color: white; display:flex; align-items: center; justify-content: center; font-weight: 600; font-size: 1.1rem;">
                                            @(string.IsNullOrWhiteSpace(user.FullName) ? "?" : user.FullName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div style="font-weight: 600; color: #252424;">@user.FullName</div>
                                            <div style="font-size: 0.85rem; color: #605E5C;">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (user.Roles.Any())
                                    {
                                        @foreach (var role in user.Roles)
                                        {
                                            var roleClass = role switch
                                            {
                                                "Manager" => "role-manager",
                                                "Project Lead" => "role-lead",
                                                "Project Coordinator" => "role-coordinator",
                                                "Employee" => "role-employee",
                                                _ => "role-employee"
                                            };
                                            <span class="role-badge @roleClass">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary border">No Role</span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge" style="background: #DFF6DD; color: #107C10; border: 1px solid #107C10;">
                                            <i class="fas fa-check-circle"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background: #FDE7E9; color: #A4262C; border: 1px solid #A4262C;">
                                            <i class="fas fa-ban"></i> Inactive
                                        </span>
                                    }
                                </td>
                                <td>
                                    <small class="text-muted fw-bold">
                                        <i class="fas fa-check-double text-success"></i> @user.CompletedTasks / @user.TotalTasks
                                    </small>
                                </td>
                                <td>
                                    <div class="action-buttons justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn-icon btn-edit" title="Edit User">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="ResetPassword" asp-route-id="@user.Id" class="btn-icon btn-reset" title="Reset Password">
                                            <i class="fas fa-key"></i>
                                        </a>
                                        <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-icon btn-toggle" title="@(user.IsActive ? "Deactivate" : "Activate")">
                                                <i class="fas fa-@(user.IsActive ? "lock" : "unlock")"></i>
                                            </button>
                                        </form>
                                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-icon btn-delete" title="Delete User">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-light border text-center py-5">
            <i class="fas fa-users-slash mb-3" style="font-size: 3rem; color: #EDEBE9;"></i>
            <h5 class="text-dark">No users found</h5>
            <p class="text-muted">Get started by <a asp-action="Create" class="text-decoration-none">creating the first user</a>.</p>
        </div>
    }
</div>
