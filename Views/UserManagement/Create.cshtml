@model OfficeTaskManagement.ViewModels.UserManagement.CreateUserViewModel

@{
    ViewData["Title"] = "Create New User";
}

<style>
    .item-editor-container {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
    }

    .item-editor-main {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 2rem;
    }

    .item-editor-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #605E5C;
        text-transform: uppercase;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #EDEBE9;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #252424;
        display: block;
        font-size: 0.9rem;
    }

    .form-control {
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 0.625rem 0.875rem;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control:focus {
        border-color: #0078D4;
        box-shadow: 0 0 0 3px rgba(0, 120, 212, 0.1);
        outline: none;
    }

    .password-help {
        font-size: 0.8rem;
        color: #605E5C;
        margin-top: 0.4rem;
    }

    .sidebar-panel {
        background: #F3F2F1;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.25rem;
    }

    .sidebar-panel-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin: 0 0 1rem 0;
        text-transform: uppercase;
    }

    .roles-container {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
    }

    .form-check-input {
        margin: 0;
        cursor: pointer;
    }

    .form-check-label {
        margin-bottom: 0;
        cursor: pointer;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .info-box {
        background: #F8F8F8;
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 1rem;
        margin-top: 1.25rem;
    }

    .info-box strong {
        color: #0078D4;
        font-size: 0.85rem;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.5rem;
    }

    .info-box ul {
        margin-bottom: 0;
        padding-left: 1.25rem;
    }

    .info-box li {
        margin-bottom: 0.25rem;
        font-size: 0.85rem;
        color: #605E5C;
    }
    
    .info-box li strong {
        display: inline;
        color: #252424;
        text-transform: none;
    }

    .required-field::after {
        content: "*";
        color: #A4262C;
        margin-left: 0.25rem;
    }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 style="font-size: 1.5rem; margin: 0;"><i class="fas fa-user-plus text-primary"></i> Create User</h1>
        <p class="text-muted mb-0 small">Provision a new account and specify roles</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left"></i> Back to Users
    </a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="item-editor-container">
        <!-- Main Editor Area -->
        <div class="item-editor-main">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-image"></i> Profile Avatar</h3>
                <div class="d-flex align-items-center gap-4">
                    <div style="width: 100px; height: 100px; border-radius: 50%; border: 2px solid #EDEBE9; overflow: hidden; background: #F8F8F8; display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-user text-muted" style="font-size: 3rem;"></i>
                    </div>
                    <div class="flex-grow-1">
                        <label asp-for="Avatar" class="form-label text-dark fw-bold">Upload Avatar</label>
                        <input asp-for="Avatar" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="Avatar" class="text-danger small"></span>
                        <div class="text-muted mt-1 small">Recommended size: 200x200px. JPG, PNG or GIF.</div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-id-card"></i> Profile Details</h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="FullName" class="form-label required-field">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="Jane Doe" />
                            <span asp-validation-for="FullName" class="text-danger small d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Email" class="form-label required-field">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="user@company.com" />
                            <span asp-validation-for="Email" class="text-danger small d-block"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section mb-0">
                <h3 class="form-section-title"><i class="fas fa-key"></i> Security Credentials</h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Password" class="form-label required-field">Password</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <div class="password-help">
                                <i class="fas fa-info-circle"></i> Minimum 6 characters (Aa1!).
                            </div>
                            <span asp-validation-for="Password" class="text-danger small d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="ConfirmPassword" class="form-label required-field">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small d-block"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Area -->
        <div class="item-editor-sidebar">
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Role Assignment</h3>
                
                <div class="roles-container">
                    @if (!Model.AvailableRoles.Any())
                    {
                        <p class="text-muted small mb-0">
                            <i class="fas fa-exclamation-triangle"></i> No roles configured in DB.
                        </p>
                    }
                    else
                    {
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       id="role_@role"
                                       name="SelectedRoles"
                                       value="@role"
                                       @(Model.SelectedRoles?.Contains(role) == true ? "checked" : "") />
                                <label class="form-check-label" for="role_@role">
                                    @role
                                </label>
                            </div>
                        }
                    }
                </div>

                <div class="info-box">
                    <strong>Guide</strong>
                    <ul>
                        <li><strong>Manager:</strong> Full system access</li>
                        <li><strong>Project Lead:</strong> Manage specific projects</li>
                        <li><strong>Coordinator:</strong> Oversee tasks</li>
                        <li><strong>Employee:</strong> Execute assignments</li>
                    </ul>
                </div>
            </div>

            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Actions</h3>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-plus"></i> Create User
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
