@model OfficeTaskManagement.Models.PublicHoliday
@{
    ViewData["Title"] = "Add Public Holiday";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Add Public Holiday</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Holiday Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Independence Day" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Date" class="form-label">Date</label>
                        <input asp-for="Date" type="date" class="form-control" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsFixedDate" class="form-check-input" />
                        <label class="form-check-label" asp-for="IsFixedDate">
                            Fixed date (same day every year)
                        </label>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Create Holiday</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
