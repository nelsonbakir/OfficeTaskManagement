@model IEnumerable<OfficeTaskManagement.Models.PublicHoliday>
@{
    ViewData["Title"] = "Public Holidays";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check"></i> Public Holidays</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Holiday
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Holiday Name</th>
                        <th>Date</th>
                        <th>Type</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Date.ToLongDateString()</td>
                            <td>
                                @if (item.IsFixedDate)
                                {
                                    <span class="badge bg-info">Fixed Date</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Variable</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this holiday?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">No public holidays defined.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
