@model OfficeTaskManagement.Models.TaskItem

@{
    ViewData["Title"] = "Delete Task";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this task?</h3>
<div>
    <h4>TaskItem</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Title)</dd>
        
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Status)</dd>
        
        <dt class="col-sm-2">Assignee</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Assignee.Email)</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
