@model OfficeTaskManagement.ViewModels.TaskItemViewModel

@{
    ViewData["Title"] = "Create Task";
}

<h1>Create</h1>

<h4>TaskItem</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="TaskItem.Title" class="control-label"></label>
                <input asp-for="TaskItem.Title" class="form-control" />
                <span asp-validation-for="TaskItem.Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.Description" class="control-label"></label>
                <textarea asp-for="TaskItem.Description" class="form-control"></textarea>
                <span asp-validation-for="TaskItem.Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.Status" class="control-label"></label>
                <select asp-for="TaskItem.Status" class="form-control" asp-items="Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskStatus>()"></select>
                <span asp-validation-for="TaskItem.Status" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.EstimatedHours" class="control-label"></label>
                <input asp-for="TaskItem.EstimatedHours" class="form-control" />
                <span asp-validation-for="TaskItem.EstimatedHours" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.StartDate" class="control-label"></label>
                <input asp-for="TaskItem.StartDate" class="form-control" type="date" />
                <span asp-validation-for="TaskItem.StartDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.DueDate" class="control-label"></label>
                <input asp-for="TaskItem.DueDate" class="form-control" type="date" />
                <span asp-validation-for="TaskItem.DueDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.ProjectId" class="control-label"></label>
                <select asp-for="TaskItem.ProjectId" class="form-control" asp-items="Model.ProjectsList">
                    <option value="">-- Select Project --</option>
                </select>
                <span asp-validation-for="TaskItem.ProjectId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.SprintId" class="control-label"></label>
                <select asp-for="TaskItem.SprintId" class="form-control" asp-items="Model.SprintsList">
                    <option value="">-- Select Sprint --</option>
                </select>
                <span asp-validation-for="TaskItem.SprintId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.FeatureId" class="control-label"></label>
                <select asp-for="TaskItem.FeatureId" class="form-control" asp-items="Model.FeaturesList">
                    <option value="">-- Select Feature --</option>
                </select>
                <span asp-validation-for="TaskItem.FeatureId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaskItem.AssigneeId" class="control-label"></label>
                <select asp-for="TaskItem.AssigneeId" class="form-control" asp-items="Model.UsersList">
                    <option value="">-- Unassigned --</option>
                </select>
                <span asp-validation-for="TaskItem.AssigneeId" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <label asp-for="Attachment" class="control-label">Attachment</label>
                <input asp-for="Attachment" class="form-control" type="file" />
                <span asp-validation-for="Attachment" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
