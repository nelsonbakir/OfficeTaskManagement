@model OfficeTaskManagement.ViewModels.TaskItemViewModel
@{ ViewData["Title"] = "Edit Task"; }

<style>
    .task-editor-container {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
    }

    .task-editor-main {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 2rem;
    }

    .task-editor-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .task-title-input {
        font-size: 1.8rem;
        font-weight: 600;
        border: none;
        padding: 0.5rem;
        margin-bottom: 1.5rem;
        width: 100%;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
    }

    .task-title-input:focus {
        outline: none;
        border-bottom-color: #0078D4;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #605E5C;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #EDEBE9;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control, .form-select {
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 0.625rem 0.875rem;
        font-size: 0.9rem;
        width: 100%;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        outline: none;
        border-color: #0078D4;
        box-shadow: 0 0 0 3px rgba(0, 120, 212, 0.1);
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
        font-family: inherit;
    }

    /* Sidebar Panels */
    .sidebar-panel {
        background: #F3F2F1;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.25rem;
    }

    .sidebar-panel-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin: 0 0 1rem 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.85rem;
        text-align: center;
        width: 100%;
        margin-bottom: 0.75rem;
    }

    .status-badge.new {
        background: #FFE5E5;
        color: #A4373A;
    }

    .status-badge.inprogress {
        background: #FFF4CE;
        color: #8A7C0A;
    }

    .status-badge.testing {
        background: #E7E6E6;
        color: #5E5E5E;
    }

    .status-badge.done {
        background: #CFF0E7;
        color: #0B5A46;
    }

    .assignee-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #0078D4;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.8rem;
    }

    .info-item {
        margin-bottom: 1rem;
    }

    .info-label {
        font-size: 0.8rem;
        color: #605E5C;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.25rem;
    }

    .info-value {
        color: #252424;
        font-weight: 500;
    }

    .btn-row {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
    }

    .btn-row button, .btn-row a {
        flex: 1;
    }

    .action-divider {
        height: 1px;
        background: #EDEBE9;
        margin: 1rem 0;
    }

    }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 style="font-size: 1.5rem; margin: 0;">Edit Task</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left"></i> Back to Tasks
    </a>
</div>

<form asp-action="Edit" enctype="multipart/form-data">
    <div class="task-editor-container">
        <!-- Main Editor -->
        <div class="task-editor-main">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom: 1.5rem;"></div>

            <input type="hidden" asp-for="TaskItem.Id" />

            <!-- Title -->
            <input asp-for="TaskItem.Title" class="task-title-input" placeholder="Task title" />

            <!-- Description Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-align-left"></i> Description</h3>
                <div class="form-group">
                    <textarea asp-for="TaskItem.Description" class="form-control" placeholder="Add a detailed description..."></textarea>
                    <span asp-validation-for="TaskItem.Description" class="text-danger small"></span>
                </div>
            </div>

            <!-- Assignment Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-share-nodes"></i> Assignment</h3>

                <div class="form-group">
                    <label>Project</label>
                    <select asp-for="TaskItem.ProjectId" class="form-select" asp-items="Model.ProjectsList">
                        <option value="">-- Select Project --</option>
                    </select>
                    <span asp-validation-for="TaskItem.ProjectId" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label>Sprint</label>
                    <select asp-for="TaskItem.SprintId" class="form-select" asp-items="Model.SprintsList">
                        <option value="">-- Select Sprint --</option>
                    </select>
                    <span asp-validation-for="TaskItem.SprintId" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label>Feature</label>
                    <select asp-for="TaskItem.FeatureId" class="form-select" asp-items="Model.FeaturesList">
                        <option value="">-- Select Feature --</option>
                    </select>
                    <span asp-validation-for="TaskItem.FeatureId" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label>Assign To</label>
                    <select asp-for="TaskItem.AssigneeId" class="form-select" asp-items="Model.UsersList">
                        <option value="">-- Unassigned --</option>
                    </select>
                    <span asp-validation-for="TaskItem.AssigneeId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Details Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-calendar"></i> Details</h3>

                <div class="form-group">
                    <label>Start Date</label>
                    <input asp-for="TaskItem.StartDate" class="form-control" type="date" />
                    <span asp-validation-for="TaskItem.StartDate" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label>Due Date</label>
                    <input asp-for="TaskItem.DueDate" class="form-control" type="date" />
                    <span asp-validation-for="TaskItem.DueDate" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label>Estimated Hours</label>
                    <input asp-for="TaskItem.EstimatedHours" class="form-control" type="number" step="0.5" placeholder="0" />
                    <span asp-validation-for="TaskItem.EstimatedHours" class="text-danger small"></span>
                </div>
            </div>

            <!-- Attachments Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-paperclip"></i> Attachments</h3>
                <div class="form-group">
                    <input asp-for="Attachment" class="form-control" type="file" />
                    <span asp-validation-for="Attachment" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="task-editor-sidebar">
            <!-- Status Panel -->
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Status</h3>
                <select asp-for="TaskItem.Status" class="form-select" style="margin-bottom: 1rem;">
                    <option value="">-- Select Status --</option>
                    @foreach (var status in Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskStatus>()) {
                        <option value="@status.Value">@status.Text</option>
                    }
                </select>

                @if (Model.TaskItem.Status != OfficeTaskManagement.Models.Enums.TaskStatus.ToDo) {
                    <div class="status-badge @Model.TaskItem.Status.ToString().ToLower()">
                        @Model.TaskItem.Status
                    </div>
                }
            </div>

            <!-- Quick Info Panel -->
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Quick Info</h3>

                <div class="info-item">
                    <div class="info-label">Created</div>
                    <div class="info-value">@Model.TaskItem.CreatedAt.ToString("MMM dd, yyyy")</div>
                </div>

                <div class="action-divider"></div>

                @if (Model.TaskItem.Assignee != null) {
                    <div class="info-item">
                        <div class="info-label">Assigned To</div>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <div class="assignee-avatar">@Model.TaskItem.Assignee.FullName[0]</div>
                            <span class="info-value">@Model.TaskItem.Assignee.FullName</span>
                        </div>
                    </div>
                } else {
                    <div class="info-item" style="color: #605E5C;">
                        <i class="fas fa-exclamation-circle"></i> Unassigned
                    </div>
                }

                <div class="action-divider"></div>

                @if (Model.TaskItem.EstimatedHours > 0) {
                    <div class="info-item">
                        <div class="info-label">Estimated</div>
                        <div class="info-value">@Model.TaskItem.EstimatedHours hours</div>
                    </div>
                }
            </div>

            <!-- Actions Panel -->
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Actions</h3>
                <button type="submit" class="btn btn-primary" style="width: 100%; margin-bottom: 0.75rem;">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a asp-action="Delete" asp-route-id="@Model.TaskItem.Id" class="btn btn-outline-danger" style="width: 100%;" onclick="return confirm('Delete this task?')">
                    <i class="fas fa-trash"></i> Delete
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
