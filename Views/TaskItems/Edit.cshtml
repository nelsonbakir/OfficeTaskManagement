@model OfficeTaskManagement.ViewModels.TaskItemViewModel
@using OfficeTaskManagement.Data
@inject ApplicationDbContext DbContext
@{ 
    ViewData["Title"] = "Edit Task"; 
    var allUsers = DbContext.Users.ToList();
}

<style>
    .task-editor-container {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
    }

    .task-editor-main {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 2rem;
    }

    .task-editor-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .task-title-input {
        font-size: 1.8rem;
        font-weight: 600;
        border: none;
        padding: 0.5rem;
        margin-bottom: 1.5rem;
        width: 100%;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
    }

    .task-title-input:focus {
        outline: none;
        border-bottom-color: #0078D4;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #605E5C;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #EDEBE9;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control, .form-select {
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 0.625rem 0.875rem;
        font-size: 0.9rem;
        width: 100%;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        outline: none;
        border-color: #0078D4;
        box-shadow: 0 0 0 3px rgba(0, 120, 212, 0.1);
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
        font-family: inherit;
    }

    /* Sidebar Panels */
    .sidebar-panel {
        background: #F3F2F1;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.25rem;
    }

    .sidebar-panel-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin: 0 0 1rem 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.85rem;
        text-align: center;
        width: 100%;
        margin-bottom: 0.75rem;
    }

    .status-badge.new {
        background: #FFE5E5;
        color: #A4373A;
    }

    .status-badge.inprogress {
        background: #FFF4CE;
        color: #8A7C0A;
    }

    .status-badge.testing {
        background: #E7E6E6;
        color: #5E5E5E;
    }

    .status-badge.done {
        background: #CFF0E7;
        color: #0B5A46;
    }

    .assignee-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #0078D4;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.8rem;
    }

    .info-item {
        margin-bottom: 1rem;
    }

    .info-label {
        font-size: 0.8rem;
        color: #605E5C;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.25rem;
    }

    .info-value {
        color: #252424;
        font-weight: 500;
    }

    .btn-row {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
    }

    .btn-row button, .btn-row a {
        flex: 1;
    }

    .action-divider {
        height: 1px;
        background: #EDEBE9;
        margin: 1rem 0;
    }

    /* Attachments & Feedback Styles */
    .attachment-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .attachment-item {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        background: #FAFAFA;
    }

    .attachment-item i {
        font-size: 1.5rem;
        color: #0078D4;
        margin-right: 1rem;
    }

    .attachment-info {
        flex: 1;
    }

    .attachment-name {
        font-weight: 600;
        color: #323130;
        text-decoration: none;
    }

    .attachment-meta {
        font-size: 0.75rem;
        color: #605E5C;
    }

    /* Feedback Thread */
    .feedback-thread {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }

    .comment-card {
        display: flex;
        gap: 1rem;
    }

    .comment-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #0078D4;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        flex-shrink: 0;
    }

    .comment-content {
        flex: 1;
        background: #F3F2F1;
        padding: 1rem;
        border-radius: 0 8px 8px 8px;
    }

    .comment-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
    }

    .comment-author {
        font-weight: 600;
        color: #323130;
    }

    .comment-time {
        color: #605E5C;
    }

    .comment-text {
        color: #252424;
        white-space: pre-wrap;
    }

    /* Mention styling in text */
    .mention-badge {
        color: #0078D4;
        background: #E1DFDD;
        padding: 0 4px;
        border-radius: 2px;
        font-weight: 500;
    }

    /* Tribute.js overrides */
    .tribute-container {
        position: absolute;
        top: 0;
        left: 0;
        height: auto;
        max-height: 300px;
        max-width: 500px;
        overflow: auto;
        display: block;
        z-index: 999999;
        background-color: white;
        border-radius: 4px;
        box-shadow: 0 1.6px 3.6px 0 rgba(0,0,0,0.132), 0 0.3px 0.9px 0 rgba(0,0,0,0.108);
    }
    .tribute-container ul {
        margin: 0;
        margin-top: 2px;
        padding: 0;
        list-style: none;
    }
    .tribute-container li {
        padding: 5px 10px;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .tribute-container li.highlight {
        background: #F3F2F1;
    }
    .tribute-container li span {
        font-weight: bold;
    }
    .tribute-container li.no-match {
        cursor: default;
    }
    .tribute-container .menu-highlighted {
        font-weight: bold;
    }

    /* Compact Header Fields */
    .compact-field-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.25rem;
        background: #F8F8F8;
        padding: 1.25rem;
        border-radius: 6px;
        margin-bottom: 2rem;
        border: 1px solid #EDEBE9;
    }

    .compact-field {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .compact-field label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #605E5C;
        text-transform: uppercase;
        margin: 0;
    }

    .compact-field .form-control, 
    .compact-field .form-select {
        padding: 0.4rem 0.6rem;
        font-size: 0.85rem;
        background: white;
    }
</style>

<!-- Tribute JS CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tributejs/5.1.3/tribute.min.css" />

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 style="font-size: 1.5rem; margin: 0;">Edit Task</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left"></i> Back to Tasks
    </a>
</div>

<form asp-action="Edit" enctype="multipart/form-data">
    <div class="task-editor-container">
        <!-- Main Editor -->
        <div class="task-editor-main">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom: 1.5rem;"></div>

            <input type="hidden" asp-for="TaskItem.Id" />

            <!-- Title -->
            <input asp-for="TaskItem.Title" class="task-title-input" placeholder="Task title" />

            <!-- Compact Header Fields -->
            <div class="compact-field-grid">
                <div class="compact-field">
                    <label>Assigned To</label>
                    <select asp-for="TaskItem.AssigneeId" class="form-select" asp-items="Model.UsersList">
                        <option value="">-- Unassigned --</option>
                    </select>
                    <span asp-validation-for="TaskItem.AssigneeId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Project</label>
                    <select asp-for="TaskItem.ProjectId" class="form-select" asp-items="Model.ProjectsList">
                        <option value="">-- Select Project --</option>
                    </select>
                    <span asp-validation-for="TaskItem.ProjectId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Sprint</label>
                    <select asp-for="TaskItem.SprintId" class="form-select" asp-items="Model.SprintsList">
                        <option value="">-- Select Sprint --</option>
                    </select>
                    <span asp-validation-for="TaskItem.SprintId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Feature</label>
                    <select asp-for="TaskItem.FeatureId" class="form-select" asp-items="Model.FeaturesList">
                        <option value="">-- Select Feature --</option>
                    </select>
                    <span asp-validation-for="TaskItem.FeatureId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Parent Task</label>
                    <select asp-for="TaskItem.ParentTaskId" class="form-select" asp-items="Model.ParentTasksList">
                        <option value="">-- None (Top Level) --</option>
                    </select>
                    <span asp-validation-for="TaskItem.ParentTaskId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Type</label>
                    <select asp-for="TaskItem.Type" class="form-select" asp-items="Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskType>()"></select>
                    <span asp-validation-for="TaskItem.Type" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Priority</label>
                    <select asp-for="TaskItem.Priority" class="form-select" asp-items="Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskPriority>()"></select>
                    <span asp-validation-for="TaskItem.Priority" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Start Date</label>
                    <input asp-for="TaskItem.StartDate" class="form-control" type="date" />
                    <span asp-validation-for="TaskItem.StartDate" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Due Date</label>
                    <input asp-for="TaskItem.DueDate" class="form-control" type="date" />
                    <span asp-validation-for="TaskItem.DueDate" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Effort (Hrs)</label>
                    <input asp-for="TaskItem.EstimatedHours" class="form-control" type="number" step="0.5" placeholder="0" />
                    <span asp-validation-for="TaskItem.EstimatedHours" class="text-danger small"></span>
                </div>
            </div>

            <!-- Description Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-align-left"></i> Description</h3>
                <div class="form-group">
                    <textarea asp-for="TaskItem.Description" class="form-control" placeholder="Add a detailed description..."></textarea>
                    <span asp-validation-for="TaskItem.Description" class="text-danger small"></span>
                </div>
            </div>

            <!-- Attachments Section -->
            <div class="form-section">
                <h3 class="form-section-title">
                    <i class="fas fa-paperclip"></i> Attachments 
                    <span class="badge bg-secondary" style="font-size: 0.7rem; vertical-align: middle;">@Model.TaskItem.Attachments.Count</span>
                </h3>
                
                <div class="form-group">
                    <label class="form-label">Upload New File</label>
                    <input asp-for="Attachment" class="form-control" type="file" />
                    <span asp-validation-for="Attachment" class="text-danger small"></span>
                </div>

                @if (Model.TaskItem.Attachments.Any())
                {
                    <div class="attachment-list">
                        @foreach (var attachment in Model.TaskItem.Attachments)
                        {
                            <div class="attachment-item">
                                <i class="fas fa-file-alt"></i>
                                <div class="attachment-info">
                                    <a href="@attachment.FilePath" target="_blank" class="attachment-name">@attachment.FileName</a>
                                    <div class="attachment-meta">
                                        Uploaded by @(attachment.UploadedBy?.FullName ?? "Unknown") on @attachment.UploadedAt.ToString("MMM dd, yyyy HH:mm")
                                    </div>
                                </div>
                                <a asp-action="DeleteAttachment" asp-route-id="@attachment.Id" class="btn btn-sm btn-outline-danger" title="Delete Attachment" onclick="return confirm('Are you sure you want to delete this attachment?');">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Feedback / Discussion Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-comments"></i> Discussion & Feedback</h3>
                
                <div class="form-group mb-4">
                    <label class="form-label fw-bold">Add a Comment</label>
                    <textarea id="commentInput" name="NewCommentText" class="form-control" rows="3" placeholder="Type @@ to mention someone. Press Ctrl+Enter to save comment quickly."></textarea>
                    <button type="button" id="postCommentBtn" class="btn btn-primary mt-2" onclick="submitComment()">
                        <i class="fas fa-paper-plane"></i> Post Comment
                    </button>
                    <small class="text-muted d-block mt-1">Comments are saved asynchronously without refreshing the page.</small>
                </div>

                <div class="action-divider"></div>

                <div class="feedback-thread" id="feedbackThread">
                    @if (Model.TaskItem.Comments != null && Model.TaskItem.Comments.Any())
                    {
                        @foreach (var comment in Model.TaskItem.Comments.OrderByDescending(c => c.CreatedAt))
                        {
                            var displayComment = comment.CommentText.Replace("\n", "<br/>");
                            if (displayComment.Contains("@"))
                            {
                                foreach (var u in allUsers)
                                {
                                    if (!string.IsNullOrEmpty(u.FullName) && displayComment.Contains("@" + u.FullName, StringComparison.OrdinalIgnoreCase))
                                    {
                                        var pattern = System.Text.RegularExpressions.Regex.Escape("@" + u.FullName);
                                        displayComment = System.Text.RegularExpressions.Regex.Replace(displayComment, pattern, $"<span class='mention-badge'>@{u.FullName}</span>", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                                    }
                                }
                            }
                            <div class="comment-card">
                                <div class="comment-avatar">
                                    @(comment.User?.FullName?[0].ToString() ?? "?")
                                </div>
                                <div class="comment-content">
                                    <div class="comment-header">
                                        <span class="comment-author">@(comment.User?.FullName ?? "Unknown User")</span>
                                        <span class="comment-time">@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                                    </div>
                                    <div class="comment-text">@Html.Raw(displayComment)</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted" id="noCommentsMsg">No discussion yet. Be the first to comment!</p>
                    }
                </div>
            </div>

        </div>

        <!-- Sidebar -->
        <div class="task-editor-sidebar">
            <!-- Status Panel -->
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Status</h3>
                <select asp-for="TaskItem.Status" class="form-select" style="margin-bottom: 1rem;">
                    <option value="">-- Select Status --</option>
                    @foreach (var status in Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskStatus>()) {
                        <option value="@status.Value">@status.Text</option>
                    }
                </select>

                @if (Model.TaskItem.Status != OfficeTaskManagement.Models.Enums.TaskStatus.ToDo) {
                    <div class="status-badge @Model.TaskItem.Status.ToString().ToLower()">
                        @Model.TaskItem.Status
                    </div>
                }
            </div>

            <!-- Backlog Panel -->
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Backlog Management</h3>
                <div class="form-check" style="margin-bottom: 1rem;">
                    <input asp-for="TaskItem.IsBacklog" class="form-check-input" type="checkbox" />
                    <label asp-for="TaskItem.IsBacklog" class="form-check-label" style="display:inline-block; margin-top:0.2rem;">Currently in Backlog</label>
                </div>
            </div>

            <!-- Quick Info Panel -->
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Quick Info</h3>

                <div class="info-item">
                    <div class="info-label">Created</div>
                    <div class="info-value">@Model.TaskItem.CreatedAt.ToString("MMM dd, yyyy")</div>
                </div>

                <div class="action-divider"></div>

                @if (Model.TaskItem.Assignee != null) {
                    <div class="info-item">
                        <div class="info-label">Assigned To</div>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <div class="assignee-avatar">@Model.TaskItem.Assignee.FullName[0]</div>
                            <span class="info-value">@Model.TaskItem.Assignee.FullName</span>
                        </div>
                    </div>
                } else {
                    <div class="info-item" style="color: #605E5C;">
                        <i class="fas fa-exclamation-circle"></i> Unassigned
                    </div>
                }

                <div class="action-divider"></div>

                @if (Model.TaskItem.EstimatedHours > 0) {
                    <div class="info-item">
                        <div class="info-label">Estimated</div>
                        <div class="info-value">@Model.TaskItem.EstimatedHours hours</div>
                    </div>
                }
            </div>

            <!-- Actions Panel -->
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Actions</h3>
                <button type="submit" class="btn btn-primary" style="width: 100%; margin-bottom: 0.75rem;">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a asp-action="Delete" asp-route-id="@Model.TaskItem.Id" class="btn btn-outline-danger" style="width: 100%;" onclick="return confirm('Delete this task?')">
                    <i class="fas fa-trash"></i> Delete
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tributejs/5.1.3/tribute.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Fetch users for Tribute mentions
            fetch('/TaskItems/GetEligibleUsersForMention?projectId=' + @(Model.TaskItem.ProjectId ?? 0))
                .then(response => response.json())
                .then(users => {
                    var tribute = new Tribute({
                        values: users,
                        selectTemplate: function (item) {
                            return '@@' + item.original.value;
                        },
                        menuItemTemplate: function (item) {
                            return item.string + " (" + item.original.email + ")";
                        }
                    });

                    tribute.attach(document.getElementById('commentInput'));
                });
                
            // Handle Ctrl+Enter to submit comment
            document.getElementById('commentInput').addEventListener('keydown', function(e) {
                if (e.ctrlKey && e.keyCode == 13) {
                    submitComment();
                }
            });
        });

        function submitComment() {
            var text = document.getElementById('commentInput').value;
            var taskId = @Model.TaskItem.Id;
            
            if (!text || text.trim() === '') return;

            var btn = document.getElementById('postCommentBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Posting...';

            var formData = new FormData();
            formData.append('taskId', taskId);
            formData.append('text', text);

            fetch('/TaskItems/AddComment', {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (response.ok) {
                    return response.text();
                }
                throw new Error('Network response was not ok.');
            })
            .then(htmlPartial => {
                // Clear input
                document.getElementById('commentInput').value = '';
                
                // Hide 'no comments' message if it exists
                var noComments = document.getElementById('noCommentsMsg');
                if (noComments) noComments.style.display = 'none';

                // Prepend new comment to thread
                var thread = document.getElementById('feedbackThread');
                thread.insertAdjacentHTML('afterbegin', htmlPartial);
                
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane"></i> Post Comment';
            })
            .catch(error => {
                console.error('Error adding comment:', error);
                alert('Failed to add comment. Please try again.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane"></i> Post Comment';
            });
        }
    </script>
}
