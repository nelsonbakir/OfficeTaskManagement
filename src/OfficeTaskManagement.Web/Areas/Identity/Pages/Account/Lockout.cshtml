@page
@model LockoutModel
@{
    ViewData["Title"] = "Locked out";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1 class="text-danger"><i class="fas fa-user-lock"></i> Locked Out</h1>
            <p>This account has been locked out due to multiple failed attempts.</p>
        </div>

        <div class="auth-error-container" style="background: #FEF0F0; border-color: #F8D7DA; color: #721C24;">
            <p class="mb-0">Please try again later or contact support if you believe this is an error.</p>
        </div>

        <div class="auth-footer">
            <p><a asp-page="./Login">Back to Sign In</a></p>
        </div>
    </div>
</div>
