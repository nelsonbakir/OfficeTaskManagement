@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1><i class="fas fa-tasks"></i> TaskFlow</h1>
            <p>Sign in to your account</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="auth-error-container" role="alert"></div>

        <form id="account" method="post">
            <div class="auth-form-group">
                <label asp-for="Input.UsernameOrEmail">Username or Email</label>
                <input asp-for="Input.UsernameOrEmail" class="auth-form-control" autocomplete="username" aria-required="true" placeholder="username or your@email.com" required autofocus />
                <span asp-validation-for="Input.UsernameOrEmail" class="text-danger"></span>
            </div>

            <div class="auth-form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="auth-form-control" autocomplete="current-password" aria-required="true" placeholder="••••••••" required />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
            </div>

            <button id="login-submit" type="submit" class="auth-btn-primary">
                <i class="fas fa-sign-in-alt"></i> Sign In
            </button>
        </form>

        <div class="auth-footer">
            <p>
                <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
            </p>
            <p>
                Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
            </p>
            <p>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
