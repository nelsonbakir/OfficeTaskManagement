@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1><i class="fas fa-sign-out-alt"></i> Logged Out</h1>
            <p>You have been successfully logged out.</p>
        </div>

        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="auth-btn-primary">
                        <i class="fas fa-sign-out-alt"></i> Click here to Log Out
                    </button>
                </form>
            }
            else
            {
                <div class="auth-error-container" style="background: #F0FDF4; border-color: #BBF7D0; color: #166534;">
                    <p class="mb-0">You have successfully logged out of the application. See you soon!</p>
                </div>
            }
        }

        <div class="auth-footer">
            <p><a asp-page="./Login">Sign In Again</a></p>
        </div>
    </div>
</div>
