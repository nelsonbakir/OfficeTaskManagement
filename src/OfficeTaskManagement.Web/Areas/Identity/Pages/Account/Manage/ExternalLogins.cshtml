@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "Manage your external logins";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<partial name="_StatusMessage" for="StatusMessage" />
<div class="mb-4">
    <h4 class="fw-bold mb-0">External Logins</h4>
    <p class="text-muted small">Manage the external services you use to log in to your account.</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

@if (Model.CurrentLogins?.Count > 0)
{
    <h5 class="mb-3 d-flex align-items-center"><i class="fas fa-id-card me-2 text-primary"></i> Registered External Logins</h5>
    <div class="table-responsive mb-5 border rounded-3 overflow-hidden">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3">Provider</th>
                    <th class="text-end pe-4 py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var login in Model.CurrentLogins)
                {
                    <tr>
                        <td class="ps-4 fw-bold" id="@($"login-provider-{login.LoginProvider}")">
                            <i class="fas fa-link me-2 text-secondary small"></i>@login.ProviderDisplayName
                        </td>
                        <td class="text-end pe-4">
                            @if (Model.ShowRemoveButton)
                            {
                                <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post">
                                    <div>
                                        <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                                        <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3 d-inline-flex align-items-center" title="Remove this @login.ProviderDisplayName login from your account" style="border-radius: 8px;">
                                            <i class="fas fa-trash-alt me-1"></i> Remove
                                        </button>
                                    </div>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-light text-secondary">Default Provider</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.OtherLogins?.Count > 0)
{
    <h5 class="mb-3 d-flex align-items-center"><i class="fas fa-plus-circle me-2 text-primary"></i> Connect New Service</h5>
    <div class="p-4 bg-light rounded-4 border border-dashed text-center">
        <form id="link-login-form" asp-page-handler="LinkLogin" method="post" class="form-horizontal">
            <div id="socialLoginList" class="d-flex flex-wrap justify-content-center gap-2">
                @foreach (var provider in Model.OtherLogins)
                {
                    <button id="@($"link-login-button-{provider.Name}")" type="submit" class="profile-btn-save d-inline-flex align-items-center px-4 py-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account" style="width: auto; margin-top: 0; font-size: 0.9rem;">
                        <i class="fas fa-share me-2"></i> Connect @provider.DisplayName
                    </button>
                }
            </div>
        </form>
    </div>
}
