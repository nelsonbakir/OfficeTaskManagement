@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="mb-4">
    <h4 class="fw-bold mb-0">Personal Data</h4>
    <p class="text-muted small">Manage your data and account export options.</p>
</div>
<!-- 
<partial name="_StatusMessage" for="StatusMessage" /> -->

<div class="alert alert-info border-0 shadow-sm mb-4" style="background: #f0f9ff; color: #0369a1;">
    <div class="d-flex align-items-center">
        <i class="fas fa-info-circle me-3 fs-4"></i>
        <p class="mb-0 small">Your account contains personal data that you have provided to us. This page allows you to download or delete that data.</p>
    </div>
</div>

<div class="card border-danger mb-4 overflow-hidden" style="border-radius: 12px; border-style: dashed !important;">
    <div class="card-body bg-danger bg-opacity-10 py-4">
        <h5 class="text-danger fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Danger Zone</h5>
        <p class="text-danger-emphasis mb-0 small">
            Deleting this data will <strong>permanently remove your account</strong>, and this action cannot be undone. All your project history and tasks will be lost.
        </p>
    </div>
</div>

<div class="d-flex flex-wrap gap-3 mt-4 pt-3 border-top">
    <form id="download-data" asp-page="DownloadPersonalData" method="post">
        <button class="profile-btn-save" type="submit">
            <i class="fas fa-download me-2"></i> Download Data
        </button>
    </form>
    <a id="delete" asp-page="DeletePersonalData" class="btn btn-outline-danger px-4 d-flex align-items-center" style="border-radius: 10px; font-weight: 600;">
        <i class="fas fa-user-times me-2"></i> Delete Account
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
