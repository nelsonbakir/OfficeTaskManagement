@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure authenticator app";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<div class="mb-4 pb-2 border-bottom">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h4 class="fw-bold mb-0">Configure Authenticator App</h4>
            <p class="text-muted small mb-0">Enhance your account security with time-based codes.</p>
        </div>
        <a asp-page="./TwoFactorAuthentication" class="btn btn-sm btn-outline-secondary d-flex align-items-center px-3" style="border-radius: 8px;">
            <i class="fas fa-arrow-left me-2"></i> Cancel
        </a>
    </div>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="authenticator-steps">
    <div class="step mb-5">
        <h5 class="fw-bold d-flex align-items-center"><span class="badge bg-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.85rem;">1</span> Download App</h5>
        <div class="ms-5">
            <p class="text-secondary small">Download a 2FA app like <strong>Microsoft Authenticator</strong> or <strong>Google Authenticator</strong>.</p>
            <div class="d-flex gap-2">
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072" class="btn btn-sm btn-outline-light border text-dark bg-light px-3" style="border-radius: 8px;"><i class="fab fa-android me-1"></i> Android</a>
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073" class="btn btn-sm btn-outline-light border text-dark bg-light px-3" style="border-radius: 8px;"><i class="fab fa-apple me-1"></i> iOS</a>
            </div>
        </div>
    </div>

    <div class="step mb-5">
        <h5 class="fw-bold d-flex align-items-center"><span class="badge bg-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.85rem;">2</span> Scan QR Code</h5>
        <div class="ms-5">
            <p class="text-secondary small mb-3">Scan this code or enter key: <code class="bg-light p-1 px-2 rounded border mx-1 font-monospace">@Model.SharedKey</code></p>
            <div class="p-3 bg-white border border-light-subtle rounded-4 shadow-sm d-inline-block">
                <div id="qrCode"></div>
                <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
            </div>
        </div>
    </div>

    <div class="step">
        <h5 class="fw-bold d-flex align-items-center"><span class="badge bg-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.85rem;">3</span> Verify Code</h5>
        <div class="ms-5">
            <p class="text-secondary small mb-3">Enter the 6-digit code from your app to complete setup.</p>
            
            <form id="send-code" method="post" style="max-width: 320px;">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                <div class="profile-form-group mb-4">
                    <input asp-for="Input.Code" class="profile-form-control text-center font-monospace fs-5 fw-bold" autocomplete="off" placeholder="000000" maxlength="6" style="letter-spacing: 4px; padding: 1rem;" />
                    <span asp-validation-for="Input.Code" class="text-danger small"></span>
                </div>
                <button type="submit" class="profile-btn-save w-100 py-3" style="border-radius: 12px; box-shadow: 0 4px 12px rgba(0, 120, 212, 0.2);">
                    <i class="fas fa-check-circle me-2"></i> Activate Authenticator
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
