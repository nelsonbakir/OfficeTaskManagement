@page
@model IndexModel
@{
    ViewData["Title"] = "Profile Management";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="mb-4">
    <h4 class="fw-bold mb-0">Public Profile</h4>
    <p class="text-muted small">Update your personal information and how others see you.</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="profile-form" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-4" role="alert"></div>

    <div class="profile-avatar-section">
        <div class="profile-avatar-preview">
            @if (!string.IsNullOrEmpty(Model.Input.AvatarPath))
            {
                <img src="@Model.Input.AvatarPath" alt="Avatar" />
            }
            else
            {
                <i class="fas fa-user"></i>
            }
        </div>
        <div class="flex-grow-1">
            <label asp-for="Input.Avatar" class="form-label fw-bold">Update Profile Picture</label>
            <input asp-for="Input.Avatar" type="file" class="form-control mb-1" accept="image/*" />
            <div class="form-text">JPG, PNG or WebP images are supported.</div>
            <span asp-validation-for="Input.Avatar" class="text-danger"></span>
        </div>
    </div>

    <div class="profile-form-grid">
        <div class="profile-form-group">
            <label asp-for="Input.Username"></label>
            <input asp-for="Input.Username" class="profile-form-control" placeholder="Your unique username" />
            <span asp-validation-for="Input.Username" class="text-danger"></span>
        </div>

        <div class="profile-form-group">
            <label asp-for="Input.FullName"></label>
            <input asp-for="Input.FullName" class="profile-form-control" placeholder="Your full name" />
            <span asp-validation-for="Input.FullName" class="text-danger"></span>
        </div>

        <div class="profile-form-group">
            <label asp-for="Input.PhoneNumber"></label>
            <input asp-for="Input.PhoneNumber" class="profile-form-control" placeholder="Your phone number" />
            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button id="update-profile-button" type="submit" class="profile-btn-save">
            <i class="fas fa-save me-2"></i> Save Changes
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
