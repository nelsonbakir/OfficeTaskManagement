@page
@model ResetAuthenticatorModel
@{
    ViewData["Title"] = "Reset authenticator key";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<div class="mb-4 d-flex align-items-center justify-content-between">
    <div>
        <h4 class="fw-bold mb-0 text-danger">Reset Authenticator</h4>
        <p class="text-muted small mb-0">Invalidate current keys and start fresh.</p>
    </div>
    <a asp-page="./TwoFactorAuthentication" class="btn btn-sm btn-outline-secondary d-flex align-items-center px-3" style="border-radius: 8px;">
        <i class="fas fa-arrow-left me-2"></i> Cancel
    </a>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="alert alert-danger border-0 shadow-sm mb-4" style="background: #fef2f2; color: #991b1b; border-radius: 12px;">
    <div class="d-flex align-items-center mb-2">
        <i class="fas fa-exclamation-circle me-2 fs-4"></i>
        <h5 class="mb-0 fw-bold">Critical Security Action</h5>
    </div>
    <p class="mb-2 small"><strong>If you reset your authenticator key, your authenticator app will not work until you reconfigure it.</strong></p>
    <p class="mb-0 small opacity-75">This process disables 2FA until you verify your authenticator app. If you do not complete the configuration, you may lose access to your account.</p>
</div>

<div class="p-4 border rounded-4 bg-light bg-opacity-50 text-center">
    <form id="reset-authenticator-form" method="post">
        <button id="reset-authenticator-button" class="btn btn-danger w-100 py-3" type="submit" style="border-radius: 12px; font-weight: 700; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(220, 53, 69, 0.25);">
            <i class="fas fa-redo-alt me-2"></i> Reset Authenticator Key
        </button>
        <p class="mt-3 text-muted small mb-0">Your recovery codes will also be invalidated.</p>
    </form>
</div>
