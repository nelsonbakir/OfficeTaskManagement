@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="mb-4">
    <h4 class="fw-bold mb-0">Security Password</h4>
    <p class="text-muted small">Update your account password to stay secure.</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="change-password-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-4" role="alert"></div>

    <div class="profile-form-grid">
        <div class="profile-form-group">
            <label asp-for="Input.OldPassword"></label>
            <input asp-for="Input.OldPassword" class="profile-form-control" autocomplete="current-password" aria-required="true" placeholder="Enter your current password" />
            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
        </div>

        <div class="profile-form-group">
            <label asp-for="Input.NewPassword"></label>
            <input asp-for="Input.NewPassword" class="profile-form-control" autocomplete="new-password" aria-required="true" placeholder="Enter your new password" />
            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
        </div>

        <div class="profile-form-group">
            <label asp-for="Input.ConfirmPassword"></label>
            <input asp-for="Input.ConfirmPassword" class="profile-form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm your new password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="profile-btn-save">
            <i class="fas fa-key me-2"></i> Update Password
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
