@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Generate two-factor authentication (2FA) recovery codes";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<div class="mb-4 d-flex align-items-center justify-content-between">
    <div>
        <h4 class="fw-bold mb-0 text-warning-emphasis">Reset Recovery Codes</h4>
        <p class="text-muted small mb-0">Generate new fallback codes for account access.</p>
    </div>
    <a asp-page="./TwoFactorAuthentication" class="btn btn-sm btn-outline-secondary d-flex align-items-center px-3" style="border-radius: 8px;">
        <i class="fas fa-arrow-left me-2"></i> Back
    </a>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="alert alert-warning border-0 shadow-sm mb-4" style="background: #fffbeb; color: #92400e; border-radius: 12px;">
    <div class="d-flex align-items-center mb-2">
        <i class="fas fa-exclamation-triangle me-2 fs-4"></i>
        <h5 class="mb-0 fw-bold">Critical Security Information</h5>
    </div>
    <p class="mb-2 small"><strong>Put these codes in a safe place.</strong> If you lose your device and don't have the recovery codes, you will lose access to your account permanently.</p>
    <p class="mb-0 small opacity-75">Generating new recovery codes does not change the authenticator app keys. To change the key, you must <a asp-page="./ResetAuthenticator" class="fw-bold text-decoration-underline text-warning-emphasis">reset authenticator keys.</a></p>
</div>

<div class="p-4 border rounded-4 bg-light bg-opacity-50 text-center">
    <form method="post">
        <button class="profile-btn-save w-100 py-3" type="submit" style="background: #d97706; border-radius: 12px; box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2);">
            <i class="fas fa-redo-alt me-2"></i> Generate New Recovery Codes
        </button>
        <p class="mt-3 text-muted small mb-0">This will invalidate your existing recovery codes.</p>
    </form>
</div>
