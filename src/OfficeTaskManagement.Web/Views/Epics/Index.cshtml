@model IEnumerable<OfficeTaskManagement.Models.Epic>
@{ ViewData["Title"] = "Epics"; }

<style>
    .page-title-section {
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-title-section h1 {
        font-size: 2rem;
        font-weight: 600;
        margin: 0;
    }

    .filter-section {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
        border: 1px solid #dee2e6;
    }

    .project-header {
        background: #e9ecef;
        padding: 0.75rem 1.25rem;
        margin-top: 2rem;
        margin-bottom: 1rem;
        border-radius: 6px;
        border-left: 5px solid #0078D4;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .project-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        color: #212529;
    }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    .project-card {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.5rem;
        transition: all 0.2s ease;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .project-card:hover {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
    }

    .project-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: #0078D4;
    }

    .project-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #0078D4;
        margin: 0 0 0.5rem 0;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease;
    }

    .project-name:hover {
        color: #005A9E;
        text-decoration: none;
    }

    .project-description {
        font-size: 0.9rem;
        color: #605E5C;
        margin: 0 0 1rem 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .project-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #EDEBE9;
        font-size: 0.85rem;
        color: #605E5C;
    }

    .project-meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .project-meta-item i {
        color: #0078D4;
    }

    .project-actions {
        position: absolute;
        top: 1rem;
        right: 1rem;
        display: flex;
        gap: 0.5rem;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .project-card:hover .project-actions {
        opacity: 1;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        border-radius: 4px;
        border: 1px solid #EDEBE9;
        background: white;
        color: #605E5C;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .action-btn:hover {
        background: #F3F2F1;
        color: #0078D4;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
    }

    .empty-state i {
        font-size: 3rem;
        color: #EDEBE9;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.2rem;
        color: #605E5C;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #A19F9D;
        margin-bottom: 1.5rem;
    }
</style>

<div class="page-title-section">
    <h1><i class="fas fa-layer-group"></i> Epics</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> New Epic
    </a>
</div>

<div class="filter-section">
    <form asp-action="Index" method="get" class="row align-items-end g-3">
        <div class="col-md-4">
            <label class="form-label fw-bold small text-uppercase">Filter by Project</label>
            <select name="projectId" class="form-select" asp-items="ViewBag.ProjectId">
                <option value="">-- All Projects --</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">
                <i class="fas fa-filter"></i> Apply
            </button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </form>
</div>

@if (Model.Any()) {
    var groupedByProject = Model.GroupBy(e => e.Project?.Name ?? "Unassigned Projects");
    
    foreach (var group in groupedByProject) {
        <div class="project-header">
            <i class="fas fa-folder-open text-primary"></i>
            <h2>@group.Key</h2>
            <span class="badge bg-primary rounded-pill">@group.Count() Epics</span>
        </div>
        
        <div class="project-grid">
            @foreach (var item in group) {
                <div class="project-card">
                    <div class="project-actions">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn" title="Edit">
                            <i class="fas fa-pen-to-square"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn" title="Delete" onclick="return confirm('Are you sure?')">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                    <a asp-action="Details" asp-route-id="@item.Id" class="project-name">
                        @Html.DisplayFor(modelItem => item.Name)
                    </a>
                    <p class="project-description">
                        @Html.DisplayFor(modelItem => item.Description)
                    </p>
                    <div class="project-meta">
                        <div class="project-meta-item">
                            <i class="fas fa-calendar-alt"></i>
                            <span>@item.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="project-meta-item">
                            <i class="fas fa-user"></i>
                            <span>@item.CreatedBy?.FullName</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
} else {
    <div class="empty-state">
        <i class="fas fa-layer-group"></i>
        <h3>No epics found</h3>
        <p>Try adjusting your filter or create a new epic</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Create Epic
        </a>
    </div>
}
