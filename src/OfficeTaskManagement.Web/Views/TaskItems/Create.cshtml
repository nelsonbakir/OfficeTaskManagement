@model OfficeTaskManagement.ViewModels.TaskItemViewModel

@{
    ViewData["Title"] = "Create Task";
}

<style>
    .task-editor-container {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
    }

    .task-editor-main {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 2rem;
    }

    .task-editor-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .task-title-input {
        font-size: 1.8rem;
        font-weight: 600;
        border: none;
        padding: 0.5rem;
        margin-bottom: 1.5rem;
        width: 100%;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
    }

    .task-title-input:focus {
        outline: none;
        border-bottom-color: #0078D4;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #605E5C;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #EDEBE9;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control, .form-select {
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 0.625rem 0.875rem;
        font-size: 0.9rem;
        width: 100%;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        outline: none;
        border-color: #0078D4;
        box-shadow: 0 0 0 3px rgba(0, 120, 212, 0.1);
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
        font-family: inherit;
    }

    /* Sidebar Panels */
    .sidebar-panel {
        background: #F3F2F1;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.25rem;
    }

    .sidebar-panel-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin: 0 0 1rem 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Compact Header Fields */
    .compact-field-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.25rem;
        background: #F8F8F8;
        padding: 1.25rem;
        border-radius: 6px;
        margin-bottom: 2rem;
        border: 1px solid #EDEBE9;
    }

    .compact-field {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .compact-field label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #605E5C;
        text-transform: uppercase;
        margin: 0;
    }

    .compact-field .form-control, 
    .compact-field .form-select {
        padding: 0.4rem 0.6rem;
        font-size: 0.85rem;
        background: white;
    }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 style="font-size: 1.5rem; margin: 0;">Create Task</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left"></i> Back to Tasks
    </a>
</div>

<form asp-action="Create" enctype="multipart/form-data">
    <div class="task-editor-container">
        <!-- Main Editor -->
        <div class="task-editor-main">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom: 1.5rem;"></div>

            <!-- Title -->
            <input asp-for="TaskItem.Title" class="task-title-input" placeholder="Task title" style="margin-bottom: 0.25rem;" />
            <div id="areas-badges-preview" class="areas-preview"></div>
            <span asp-validation-for="TaskItem.Title" class="text-danger small"></span>

            <!-- Compact Header Fields -->
            <div class="compact-field-grid">
                <div class="compact-field">
                    <label>Assigned To</label>
                    <select asp-for="TaskItem.AssigneeId" class="form-select" asp-items="Model.UsersList" id="AssigneeId">
                        <option value="">-- Unassigned --</option>
                    </select>
                    <div id="assignee-availability" class="mt-1" style="font-size: 0.75rem; display: none;"></div>
                    <span asp-validation-for="TaskItem.AssigneeId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Project</label>
                    <select asp-for="TaskItem.ProjectId" class="form-select" asp-items="Model.ProjectsList" id="ProjectId">
                        <option value="">-- Select Project --</option>
                    </select>
                    <span asp-validation-for="TaskItem.ProjectId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Epic</label>
                    <select asp-for="TaskItem.EpicId" class="form-select" asp-items="Model.EpicsList" id="EpicId">
                        <option value="">-- Select Epic --</option>
                    </select>
                    <span asp-validation-for="TaskItem.EpicId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Feature</label>
                    <select asp-for="TaskItem.FeatureId" class="form-select" asp-items="Model.FeaturesList" id="FeatureId">
                        <option value="">-- Select Feature --</option>
                    </select>
                    <span asp-validation-for="TaskItem.FeatureId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>User Story</label>
                    <select asp-for="TaskItem.UserStoryId" class="form-select" asp-items="Model.UserStoriesList" id="UserStoryId">
                        <option value="">-- Select User Story --</option>
                    </select>
                    <span asp-validation-for="TaskItem.UserStoryId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Sprint</label>
                    <select asp-for="TaskItem.SprintId" class="form-select" asp-items="Model.SprintsList">
                        <option value="">-- Select Sprint --</option>
                    </select>
                    <span asp-validation-for="TaskItem.SprintId" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Areas</label>
                    <select asp-for="SelectedAreaIds" class="form-select" asp-items="Model.AreasList" multiple id="areas-selector" style="height: 38px;"></select>
                </div>

                <div class="compact-field">
                    <label>Type</label>
                    <select asp-for="TaskItem.Type" class="form-select" asp-items="Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskType>()"></select>
                    <span asp-validation-for="TaskItem.Type" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Priority</label>
                    <select asp-for="TaskItem.Priority" class="form-select" asp-items="Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskPriority>()"></select>
                    <span asp-validation-for="TaskItem.Priority" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Start Date</label>
                    <input asp-for="TaskItem.StartDate" class="form-control" type="date" />
                    <span asp-validation-for="TaskItem.StartDate" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Due Date</label>
                    <input asp-for="TaskItem.DueDate" class="form-control" type="date" />
                    <span asp-validation-for="TaskItem.DueDate" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Effort (Hrs)</label>
                    <input asp-for="TaskItem.EstimatedHours" class="form-control" type="number" step="0.5" placeholder="0" />
                    <span asp-validation-for="TaskItem.EstimatedHours" class="text-danger small"></span>
                </div>

                <div class="compact-field">
                    <label>Parent Task</label>
                    <select asp-for="TaskItem.ParentTaskId" class="form-select" asp-items="Model.ParentTasksList">
                        <option value="">-- None (Top Level) --</option>
                    </select>
                    <span asp-validation-for="TaskItem.ParentTaskId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Description Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-align-left"></i> Description</h3>
                <div class="form-group">
                    <textarea asp-for="TaskItem.Description" class="form-control" placeholder="Add a detailed description..."></textarea>
                    <span asp-validation-for="TaskItem.Description" class="text-danger small"></span>
                </div>
            </div>

            <!-- Attachments Section -->
            <div class="form-section">
                <h3 class="form-section-title">
                    <i class="fas fa-paperclip"></i> Initial Attachments 
                </h3>
                <div class="form-group">
                    <label class="form-label">Upload Files</label>
                    <input asp-for="Attachments" class="form-control" type="file" multiple />
                    <span asp-validation-for="Attachments" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="task-editor-sidebar">
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Status</h3>
                <select asp-for="TaskItem.Status" class="form-select" style="margin-bottom: 1rem;">
                    @foreach (var status in Html.GetEnumSelectList<OfficeTaskManagement.Models.Enums.TaskStatus>()) {
                        <option value="@status.Value">@status.Text</option>
                    }
                </select>
                <span asp-validation-for="TaskItem.Status" class="text-danger small"></span>
            </div>

            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Backlog</h3>
                <div class="form-check" style="margin-bottom: 1rem;">
                    <input asp-for="TaskItem.IsBacklog" class="form-check-input" type="checkbox" />
                    <label asp-for="TaskItem.IsBacklog" class="form-check-label" style="display:inline-block; margin-top:0.2rem;">Push to Backlog</label>
                </div>
            </div>

            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Actions</h3>
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    <i class="fas fa-plus"></i> Create Task
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            const areaSelector = $('#areas-selector');
            const badgesPreview = document.getElementById('areas-badges-preview');

            // Initialize Select2
            areaSelector.select2({
                placeholder: "-- Select Areas --",
                width: '100%'
            });

            function updateBadges() {
                badgesPreview.innerHTML = '';
                const selectedOptions = areaSelector.select2('data');
                selectedOptions.forEach(option => {
                    const badge = document.createElement('span');
                    badge.className = 'area-badge';
                    badge.innerHTML = '<i class="fas fa-tag"></i> ' + option.text;
                    badgesPreview.appendChild(badge);
                });
            }

            areaSelector.on('change', updateBadges);
            updateBadges(); // Initial call

            // Cascading Dropdowns Logic
            const projectSelect = $('#ProjectId');
            const epicSelect = $('#EpicId');
            const featureSelect = $('#FeatureId');
            const storySelect = $('#UserStoryId');

            function clearSelect(select, placeholder) {
                select.empty();
                select.append($('<option>', { value: '', text: placeholder }));
            }

            projectSelect.on('change', function() {
                const projectId = $(this).val();
                clearSelect(epicSelect, '-- Select Epic --');
                clearSelect(featureSelect, '-- Select Feature --');
                clearSelect(storySelect, '-- Select User Story --');
                
                if (projectId) {
                    $.getJSON('/TaskItems/GetEpics', { projectId: projectId }, function(data) {
                        data.forEach(item => {
                            epicSelect.append($('<option>', { value: item.id, text: item.name }));
                        });
                    });
                }
            });

            epicSelect.on('change', function() {
                const epicId = $(this).val();
                clearSelect(featureSelect, '-- Select Feature --');
                clearSelect(storySelect, '-- Select User Story --');
                
                if (epicId) {
                    $.getJSON('/TaskItems/GetFeatures', { epicId: epicId }, function(data) {
                        data.forEach(item => {
                            featureSelect.append($('<option>', { value: item.id, text: item.name }));
                        });
                    });
                }
            });

            featureSelect.on('change', function() {
                const featureId = $(this).val();
                clearSelect(storySelect, '-- Select User Story --');
                
                if (featureId) {
                    $.getJSON('/TaskItems/GetUserStories', { featureId: featureId }, function(data) {
                        data.forEach(item => {
                            storySelect.append($('<option>', { value: item.id, text: item.name }));
                        });
                    });
                }
            });

            // AJAX Resource Availability Check
            const assigneeSelect = $('#AssigneeId');
            const startDateIn = $('#TaskItem_StartDate');
            const dueDateIn = $('#TaskItem_DueDate');
            const availDiv = $('#assignee-availability');

            function checkAssigneeAvailability() {
                const uId = assigneeSelect.val();
                let start = startDateIn.val();
                let end = dueDateIn.val();
                
                if (!start) start = new Date().toISOString().split('T')[0];
                if (!end) {
                    let d = new Date(start);
                    d.setDate(d.getDate() + 7);
                    end = d.toISOString().split('T')[0];
                }

                if (uId && start) {
                    $.get('/api/ResourceData/availability', { userId: uId, startDate: start, endDate: end })
                     .done(function(data) {
                         availDiv.show();
                         if(data.isOverAllocated) {
                             availDiv.html(`<span class="text-danger"><i class="fas fa-exclamation-circle"></i> Over-allocated (${data.currentAllocationPercent}%)</span>`);
                         } else if (data.currentAllocationPercent >= 80) {
                             availDiv.html(`<span class="text-warning text-dark"><i class="fas fa-exclamation-triangle"></i> Near Capacity (${data.currentAllocationPercent}%)</span>`);
                         } else {
                             availDiv.html(`<span class="text-success"><i class="fas fa-check-circle"></i> Available (${data.currentAllocationPercent}% load)</span>`);
                         }
                     });
                } else {
                    availDiv.hide();
                }
            }

            assigneeSelect.on('change', checkAssigneeAvailability);
            startDateIn.on('change', checkAssigneeAvailability);
            dueDateIn.on('change', checkAssigneeAvailability);

            // Real-time Availability Dots for Assignee Dropdown
            function formatAssignee(option) {
                if (!option.id) return option.text;
                var dotColor = 'transparent';
                var dataColor = $(option.element).data('avail-color');
                if (dataColor) {
                    dotColor = dataColor;
                } else {
                    // Default to gray before loaded
                    dotColor = '#ccc';
                }
                var $html = $(`<span><div style="display:inline-block; width:10px; height:10px; border-radius:50%; background-color:${dotColor}; margin-right:6px;"></div>${option.text}</span>`);
                return $html;
            }

            assigneeSelect.select2({
                placeholder: "-- Unassigned --",
                width: '100%',
                templateResult: formatAssignee,
                templateSelection: formatAssignee
            });

            function loadAssigneeAvailabilityDots() {
                var start = startDateIn.val() || new Date().toISOString().split('T')[0];
                var end = dueDateIn.val();
                if (!end) {
                    let d = new Date(start);
                    d.setDate(d.getDate() + 7);
                    end = d.toISOString().split('T')[0];
                }

                assigneeSelect.find('option').each(function() {
                    var uId = $(this).val();
                    if (!uId) return;
                    
                    var optionEl = $(this);
                    optionEl.data('avail-color', '#ccc'); // Reset to loading
                    
                    $.get('/api/ResourceData/availability', { userId: uId, startDate: start, endDate: end })
                     .done(function(data) {
                         var color = '#198754'; // Green
                         if (data.isOverAllocated || data.currentAllocationPercent > 100) color = '#dc3545'; // Red
                         else if (data.currentAllocationPercent >= 80) color = '#ffc107'; // Amber
                         
                         optionEl.data('avail-color', color);
                         // Trigger update on select2 for this element
                         if (assigneeSelect.val() === uId) assigneeSelect.trigger('change.select2');
                     });
                });
            }

            // Load dots on init and when dates change
            loadAssigneeAvailabilityDots();
            startDateIn.on('change', loadAssigneeAvailabilityDots);
            dueDateIn.on('change', loadAssigneeAvailabilityDots);

        });
    </script>
}
