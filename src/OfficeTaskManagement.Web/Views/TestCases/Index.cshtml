@model IEnumerable<OfficeTaskManagement.Models.TestCase>

@{
    ViewData["Title"] = "Test Cases";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-vial text-success"></i> Test Cases</h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus"></i> Create New
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Title</th>
                    <th>User Story</th>
                    <th>Automated</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model) {
                <tr>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none text-success">@item.Title</a>
                    </td>
                    <td>@(item.UserStory?.Title ?? "None")</td>
                    <td>
                        @if (item.IsAutomated) {
                            <span class="badge bg-success"><i class="fas fa-robot"></i> Yes</span>
                        } else {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="fas fa-edit"></i></a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1"><i class="fas fa-eye"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
</div>
