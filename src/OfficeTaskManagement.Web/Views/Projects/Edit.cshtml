@model OfficeTaskManagement.ViewModels.ProjectViewModel
@using OfficeTaskManagement.Services
@inject IMediaService MediaService

@{ ViewData["Title"] = "Edit Project"; }

<style>
    .item-editor-container {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
    }

    .item-editor-main {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 2rem;
    }

    .item-editor-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .item-title-input {
        font-size: 1.8rem;
        font-weight: 600;
        border: none;
        padding: 0.5rem;
        margin-bottom: 1.5rem;
        width: 100%;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
    }

    .item-title-input:focus {
        outline: none;
        border-bottom-color: #0078D4;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #605E5C;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #EDEBE9;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control {
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 0.625rem 0.875rem;
        font-size: 0.9rem;
        width: 100%;
        transition: all 0.2s ease;
    }

    .form-control:focus {
        outline: none;
        border-color: #0078D4;
        box-shadow: 0 0 0 3px rgba(0, 120, 212, 0.1);
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
        font-family: inherit;
    }

    .sidebar-panel {
        background: #F3F2F1;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.25rem;
    }

    .sidebar-panel-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin: 0 0 1rem 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .attachment-list {
        list-style: none;
        padding: 0;
        margin-top: 1rem;
    }

    .attachment-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem;
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .logo-preview {
        max-width: 100px;
        max-height: 100px;
        margin-bottom: 1rem;
        border: 1px solid #EDEBE9;
        padding: 5px;
        border-radius: 4px;
    }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 style="font-size: 1.5rem; margin: 0;">Edit Project</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left"></i> Back to Projects
    </a>
</div>

<form asp-action="Edit" enctype="multipart/form-data">
    <div class="item-editor-container">
        <!-- Main Editor -->
        <div class="item-editor-main">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom: 1.5rem;"></div>
            <input type="hidden" asp-for="Project.Id" />

            <!-- Title -->
            <input asp-for="Project.Name" class="item-title-input" placeholder="Project name" />
            <span asp-validation-for="Project.Name" class="text-danger small"></span>

            <!-- Logo Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-image"></i> Project Logo</h3>
                @if (!string.IsNullOrEmpty(Model.Project.LogoPath))
                {
                    <div class="logo-preview">
                        <img src="@MediaService.GetUrl(Model.Project.LogoPath)" alt="Logo" style="max-width: 100%; height: auto;" />
                    </div>
                }
                <div class="form-group">
                    <input asp-for="Logo" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="Logo" class="text-danger small"></span>
                    <small class="text-muted">Uploading a new logo will replace the current one.</small>
                </div>
            </div>

            <!-- Skills Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-tools"></i> Required Skills</h3>
                <div class="form-group">
                    <input asp-for="Project.RequiredSkills" class="form-control" placeholder="e.g. C#, SQL, React (comma-separated)" />
                    <span asp-validation-for="Project.RequiredSkills" class="text-danger small"></span>
                    <div class="text-muted small mt-1">Used to alert managers of skill-gaps during resource allocation.</div>
                </div>
            </div>

            <!-- Description Section -->
            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-align-left"></i> Description</h3>
                <div class="form-group">
                    <textarea asp-for="Project.Description" class="form-control" placeholder="Describe the project's goals and scope..." rows="8"></textarea>
                    <span asp-validation-for="Project.Description" class="text-danger small"></span>
                </div>
            </div>

            <!-- Attachments Section -->
            <div class="form-section mb-0">
                <h3 class="form-section-title"><i class="fas fa-paperclip"></i> Attachments</h3>
                
                @if (Model.Project.Attachments != null && Model.Project.Attachments.Any())
                {
                    <ul class="attachment-list">
                        @foreach (var attachment in Model.Project.Attachments)
                        {
                            <li class="attachment-item">
                                <div>
                                    <i class="fas fa-file"></i>
                                    <a href="@MediaService.GetUrl(attachment.FilePath)" target="_blank">@attachment.FileName</a>
                                    <span class="text-muted small">(@attachment.UploadedAt.ToShortDateString())</span>
                                </div>
                                <button type="submit" asp-action="DeleteAttachment" asp-route-id="@attachment.Id" class="btn btn-link text-danger p-0" onclick="return confirm('Are you sure you want to delete this attachment?')">
                                    <i class="fas fa-times"></i>
                                </button>
                            </li>
                        }
                    </ul>
                }

                <div class="form-group mt-3 mb-0">
                    <label>Add More Attachments</label>
                    <input asp-for="Attachments" type="file" class="form-control" multiple />
                    <span asp-validation-for="Attachments" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="item-editor-sidebar">
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Actions</h3>
                <button type="submit" class="btn btn-primary" style="width: 100%; margin-bottom: 0.75rem;">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a asp-action="Delete" asp-route-id="@Model.Project.Id" class="btn btn-outline-danger" style="width: 100%;">
                    <i class="fas fa-trash"></i> Delete Project
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
