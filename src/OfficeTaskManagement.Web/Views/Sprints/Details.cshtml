@model OfficeTaskManagement.Models.Sprint
@{ ViewData["Title"] = Model.Name; }

<style>
    .sprint-detail-header {
        background: white;
        border-bottom: 1px solid #EDEBE9;
        padding: 2rem;
        margin: -2rem -2rem 2rem -2rem;
        border-radius: 6px 6px 0 0;
    }

    .sprint-detail-title {
        font-size: 2rem;
        font-weight: 600;
        margin: 0 0 1.5rem 0;
        color: #252424;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-bottom: 1rem;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
    }

    .detail-label {
        color: #605E5C;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
    }

    .detail-value {
        color: #252424;
        font-weight: 500;
        font-size: 1.1rem;
    }

    .status-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.85rem;
        width: fit-content;
    }

    .status-badge.active {
        background: #D4EDDA;
        color: #155724;
    }

    .status-badge.inactive {
        background: #E8E8E8;
        color: #605E5C;
    }

    .back-button {
        margin-top: 1rem;
    }

    .tasks-section {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 2rem;
        margin-top: 2rem;
    }

    .tasks-section h2 {
        font-size: 1.3rem;
        font-weight: 600;
        margin: 0 0 1.5rem 0;
        padding-bottom: 1rem;
        border-bottom: 1px solid #EDEBE9;
    }

    .task-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .task-row {
        background: #F3F2F1;
        padding: 1rem;
        border-radius: 4px;
        border-left: 3px solid #0078D4;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.2s ease;
    }

    .task-row:hover {
        background: #EDEBE9;
        transform: translateX(4px);
    }

    .task-content {
        flex: 1;
    }

    .task-title {
        font-weight: 600;
        color: #252424;
        margin-bottom: 0.25rem;
    }

    .task-meta {
        font-size: 0.85rem;
        color: #605E5C;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .task-meta i {
        color: #0078D4;
    }

    .task-status {
        padding: 0.25rem 0.75rem;
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 3px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .task-actions {
        display: flex;
        gap: 0.5rem;
    }

    .task-action-btn {
        padding: 0.5rem 0.75rem;
        border-radius: 4px;
        border: 1px solid #EDEBE9;
        background: white;
        color: #0078D4;
        text-decoration: none;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .task-action-btn:hover {
        background: white;
        color: #005A9E;
        border-color: #0078D4;
    }

    .empty-tasks {
        text-align: center;
        padding: 2rem;
        color: #605E5C;
    }

    .empty-tasks i {
        font-size: 2rem;
        color: #EDEBE9;
        display: block;
        margin-bottom: 0.5rem;
    }

    .action-buttons {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #EDEBE9;
    }

    .action-buttons a, .action-buttons button {
        padding: 0.625rem 1.25rem;
        border-radius: 4px;
        border: none;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .action-buttons .btn-primary {
        background: #0078D4;
        color: white;
    }

    .action-buttons .btn-primary:hover {
        background: #005A9E;
    }

    .action-buttons .btn-secondary {
        background: white;
        border: 1px solid #EDEBE9;
        color: #252424;
    }

    .action-buttons .btn-secondary:hover {
        background: #F3F2F1;
    }

    .action-buttons .btn-danger {
        background: white;
        border: 1px solid #E81123;
        color: #E81123;
    }

    .action-buttons .btn-danger:hover {
        background: #FEE2E2;
    }
</style>

<div class="sprint-detail-header">
    <h1 class="sprint-detail-title">
        <i class="fas fa-rocket"></i> @Model.Name
    </h1>

    <div class="detail-grid">
        <div class="detail-item">
            <span class="detail-label">Project</span>
            <span class="detail-value">@Model.Project?.Name</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Start Date</span>
            <span class="detail-value">@Model.StartDate.ToString("MMM dd, yyyy")</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">End Date</span>
            <span class="detail-value">@Model.EndDate.ToString("MMM dd, yyyy")</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Status</span>
            <div class="status-badge @(Model.IsActive ? "active" : "inactive")">
                @(Model.IsActive ? "Active" : "Completed")
            </div>
        </div>
    </div>

    <div class="action-buttons">
        @if(User.IsInRole("Manager") || User.IsInRole("Project Lead")) {
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-primary">
                <i class="fas fa-edit"></i> Edit Sprint
            </a>
            <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn-danger" onclick="return confirm('Are you sure?')">
                <i class="fas fa-trash"></i> Delete
            </a>
        }
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="tasks-section">
    <h2>
        <i class="fas fa-tasks"></i> Tasks in Sprint (@Model.Tasks.Count)
    </h2>

    @if (Model.Tasks.Any()) {
        <div class="task-list">
            @foreach (var task in Model.Tasks.OrderBy(t => t.Status)) {
                <div class="task-row">
                    <div class="task-content">
                        <div class="task-title">@task.Title</div>
                        <div class="task-meta">
                            @if(task.Assignee != null) {
                                <span>
                                    <i class="fas fa-user-circle"></i> @task.Assignee.FullName
                                </span>
                            }
                            @if(!string.IsNullOrEmpty(task.Description)) {
                                <span style="margin: 0 0.5rem;">•</span>
                                <span title="@task.Description">
                                    <i class="fas fa-align-left"></i> Description
                                </span>
                            }
                        </div>
                    </div>
                    <div class="task-status">@task.Status</div>
                    <div class="task-actions">
                        <a asp-controller="TaskItems" asp-action="Edit" asp-route-id="@task.Id" class="task-action-btn" title="Edit">
                            <i class="fas fa-pen-to-square"></i> Edit
                        </a>
                    </div>
                </div>
            }
        </div>
    } else {
        <div class="empty-tasks">
            <i class="fas fa-inbox"></i>
            <p>No tasks in this sprint yet</p>
        </div>
    }
</div>
