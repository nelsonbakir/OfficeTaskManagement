@model OfficeTaskManagement.Models.Sprint
@{ ViewData["Title"] = "Delete Sprint"; }

<style>
    .delete-container {
        max-width: 600px;
        margin: 4rem auto;
        background: white;
        border: 1px solid #FEE2E2;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(232, 17, 35, 0.08);
        overflow: hidden;
    }
    
    .delete-header {
        background: #FDF3F4;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #FEE2E2;
        display: flex;
        align-items: center;
        gap: 1rem;
        color: #E81123;
    }
    
    .delete-header i {
        font-size: 2rem;
    }
    
    .delete-header h2 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 600;
    }
    
    .delete-body {
        padding: 2rem;
    }

    .delete-message {
        font-size: 1.1rem;
        color: #252424;
        margin-bottom: 1.5rem;
        line-height: 1.5;
    }
    
    .item-preview {
        background: #F8F8F8;
        padding: 1.5rem;
        border-radius: 6px;
        border: 1px solid #EDEBE9;
        margin-bottom: 2rem;
    }
    
    .item-preview-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #252424;
        margin: 0 0 0.5rem 0;
    }
    
    .item-preview-meta {
        color: #605E5C;
        font-size: 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .meta-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .delete-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #EDEBE9;
    }
    
    .delete-actions form {
        margin: 0;
    }

    .btn-danger {
        background-color: #E81123;
        border-color: #E81123;
    }

    .btn-danger:hover {
        background-color: #C50F1F;
        border-color: #C50F1F;
    }
</style>

<div class="delete-container">
    <div class="delete-header">
        <i class="fas fa-exclamation-triangle"></i>
        <h2>Delete Sprint</h2>
    </div>
    
    <div class="delete-body">
        <p class="delete-message">
            Are you sure you want to permanently delete this sprint? Associated tasks will be detached from this sprint but will not be deleted.
        </p>
        
        <div class="item-preview">
            <h3 class="item-preview-title">@Model.Name</h3>
            <div class="item-preview-meta">
                <div class="meta-row">
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                    <i class="fas fa-folder ms-2"></i> Project: @(Model.Project?.Name ?? "None")
                </div>
                <div class="meta-row mt-1">
                    <i class="fas fa-calendar"></i>
                    <span>@Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</span>
                </div>
            </div>
        </div>
        
        <div class="delete-actions">
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">
                    <i class="fas fa-trash"></i> Delete Confirmed
                </button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                Cancel
            </a>
        </div>
    </div>
</div>
