<!-- Pause (Hold) Project -->
<div class="modal fade" id="holdProjectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="fas fa-pause-circle text-warning me-2"></i>Put Project On Hold</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Project</label>
                    <select id="holdProjectId" class="form-select">
                        @foreach (var p in Model.AllProjects) { <option value="@p.Value">@p.Text</option> }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Reason <span class="text-danger">*</span></label>
                    <textarea id="holdProjectNotes" class="form-control" rows="3" placeholder="Why is this project being paused? (required for audit log)"></textarea>
                </div>
                <div class="alert alert-warning py-2" style="font-size: 0.85rem;">
                    <h6 class="alert-heading fw-bold mb-1"><i class="fas fa-magic me-1"></i> System Action</h6>
                    <ul class="mb-0 ps-3">
                        <li>Project Strategic Status becomes <span class="badge bg-warning text-dark">On Hold</span></li>
                        <li><strong>All active in-progress tasks</strong> across the entire project will be instantly soft-paused.</li>
                        <li>Committed hours for these tasks will be <strong>removed from Org Capacity</strong> until resumed.</li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-warning" onclick="submitHoldProject()"><i class="fas fa-pause me-1"></i>Confirm Hold</button></div>
        </div>
    </div>
</div>

<!-- Delay Project -->
<div class="modal fade" id="delayProjectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="fas fa-hourglass-half text-orange me-2" style="color:#e67e22;"></i>Delay Project</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Project</label>
                    <select id="delayProjectId" class="form-select">
                        @foreach (var p in Model.AllProjects) { <option value="@p.Value">@p.Text</option> }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Reason / New Timeline Notes</label>
                    <textarea id="delayProjectNotes" class="form-control" rows="3" placeholder="Describe reason for delay and any revised timeline"></textarea>
                </div>
                <div class="alert alert-info py-2" style="font-size: 0.85rem;">
                    <h6 class="alert-heading fw-bold mb-1"><i class="fas fa-info-circle me-1"></i> System Action</h6>
                    <p class="mb-0">Project Strategic Status becomes <span class="badge" style="background-color:#e67e22;">Delayed</span>. Tasks and capacity remain unaffected, but this signals an officially recognized timeline extension to stakeholders.</p>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-warning" onclick="submitDelayProject()">Confirm Delay</button></div>
