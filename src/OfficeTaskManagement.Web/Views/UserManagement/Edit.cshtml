@model OfficeTaskManagement.ViewModels.UserManagement.EditUserViewModel
@inject OfficeTaskManagement.Services.IMediaService MediaService

@{
    ViewData["Title"] = "Edit User";
}

<style>
    .item-editor-container {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
    }

    .item-editor-main {
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 2rem;
    }

    .item-editor-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #605E5C;
        text-transform: uppercase;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #EDEBE9;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #252424;
        display: block;
        font-size: 0.9rem;
    }

    .form-control {
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 0.625rem 0.875rem;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control:focus {
        border-color: #0078D4;
        box-shadow: 0 0 0 3px rgba(0, 120, 212, 0.1);
        outline: none;
    }

    .form-control:disabled {
        background-color: #F8F8F8;
        cursor: not-allowed;
        color: #605E5C;
    }

    .disabled-help {
        font-size: 0.8rem;
        color: #605E5C;
        margin-top: 0.4rem;
    }

    .sidebar-panel {
        background: #F3F2F1;
        border: 1px solid #EDEBE9;
        border-radius: 6px;
        padding: 1.25rem;
    }

    .sidebar-panel-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #252424;
        margin: 0 0 1rem 0;
        text-transform: uppercase;
    }

    .roles-container {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
    }

    .form-check-input {
        margin: 0;
        cursor: pointer;
    }

    .form-check-label {
        margin-bottom: 0;
        cursor: pointer;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .toggle-switch {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 1rem;
        margin-top: 1rem;
    }

    .toggle-switch .form-check-input {
        margin-top: 0.25rem;
    }

    .info-box {
        background: #FDF3F4;
        border: 1px solid #FEE2E2;
        border-radius: 4px;
        padding: 1rem;
        margin-top: 1.25rem;
    }

    .info-box strong {
        color: #A4262C;
        font-size: 0.85rem;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.5rem;
    }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 style="font-size: 1.5rem; margin: 0;"><i class="fas fa-user-edit text-primary"></i> Edit User</h1>
        <p class="text-muted mb-0 small">@Model.Email</p>
    </div>
    <div>
        <a asp-action="ResetPassword" asp-route-id="@Model.Id" class="btn btn-warning btn-sm me-2">
            <i class="fas fa-key"></i> Reset Password
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i> Back to Users
        </a>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    <div class="item-editor-container">
        <!-- Main Editor Area -->
        <div class="item-editor-main">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="AvatarPath" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-section">
                <h3 class="form-section-title"><i class="fas fa-image"></i> Profile Avatar</h3>
                <div class="d-flex align-items-center gap-4">
                    <div style="width: 100px; height: 100px; border-radius: 50%; border: 2px solid #EDEBE9; overflow: hidden; background: #F8F8F8; display: flex; align-items: center; justify-content: center;">
                        @if (!string.IsNullOrEmpty(Model.AvatarPath))
                        {
                            <img src="@MediaService.GetUrl(Model.AvatarPath)" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar" />
                        }
                        else
                        {
                            <i class="fas fa-user text-muted" style="font-size: 3rem;"></i>
                        }
                    </div>
                    <div class="flex-grow-1">
                        <label asp-for="Avatar" class="form-label">Update Avatar</label>
                        <input asp-for="Avatar" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="Avatar" class="text-danger small"></span>
                        <div class="text-muted mt-1 small">Recommended size: 200x200px. JPG, PNG or GIF.</div>
                    </div>
                </div>
            </div>

            <div class="form-section mb-0">
                <h3 class="form-section-title"><i class="fas fa-id-card"></i> Profile Details</h3>
                
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" disabled />
                    <div class="disabled-help">
                        <i class="fas fa-lock"></i> Email identity cannot be altered.
                    </div>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="FullName" class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small d-block"></span>
                </div>
            </div>
        </div>

        <!-- Sidebar Area -->
        <div class="item-editor-sidebar">
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Role Assignment</h3>
                
                <div class="roles-container">
                    @if (!Model.AvailableRoles.Any())
                    {
                        <p class="text-muted small mb-0">
                            <i class="fas fa-exclamation-triangle"></i> No roles configured in DB.
                        </p>
                    }
                    else
                    {
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       id="role_@role"
                                       name="SelectedRoles"
                                       value="@role"
                                       @(Model.SelectedRoles?.Contains(role) == true ? "checked" : "") />
                                <label class="form-check-label" for="role_@role">
                                    @role
                                </label>
                            </div>
                        }
                    }
                </div>
            </div>
            
            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Account Status</h3>
                
                <div class="toggle-switch">
                    <input type="checkbox" class="form-check-input" asp-for="IsActive" />
                    <label class="form-check-label">
                        <strong class="d-block mb-1">Account Active</strong>
                        <span class="text-muted d-block" style="font-size: 0.8rem; line-height: 1.4;">
                            Uncheck to prevent this user from logging in without destroying their data.
                        </span>
                    </label>
                </div>
            </div>

            <div class="sidebar-panel">
                <h3 class="sidebar-panel-title">Actions</h3>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
