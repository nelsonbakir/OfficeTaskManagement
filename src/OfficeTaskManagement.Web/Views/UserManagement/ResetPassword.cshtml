@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="profile-container">
    <div class="profile-card">
        <div class="profile-card-header" style="background: #FFF4CE; border-bottom: 1px solid #FDE68A;">
            <h2 style="color: #734C00;"><i class="fas fa-shield-alt me-2"></i> Administrative Password Reset</h2>
        </div>
        
        <div class="profile-card-body">
            <p class="mb-4" style="font-size: 1.1rem; color: #252424;">
                Resetting password for: <strong>@Model.Email</strong>
            </p>

            <form asp-action="ResetPassword" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Email" />
                
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <div class="profile-form-grid">
                    <div class="profile-form-group">
                        <label asp-for="NewPassword" class="required-field"></label>
                        <input asp-for="NewPassword" class="profile-form-control" placeholder="Enter new password" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                        <div class="form-text mt-1">Minimum 6 characters, include uppercase, lowercase, and numbers.</div>
                    </div>

                    <div class="profile-form-group">
                        <label asp-for="ConfirmPassword" class="required-field"></label>
                        <input asp-for="ConfirmPassword" class="profile-form-control" placeholder="Confirm new password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <div class="alert alert-warning mt-4" style="background: #FFF9E6; border: 1px solid #FFE58F; color: #856404;">
                    <i class="fas fa-info-circle me-2"></i> The user will be able to log in with the new password immediately.
                </div>

                <div class="mt-4 d-flex gap-3">
                    <button type="submit" class="profile-btn-save" style="background: #FFB900; color: #000;">
                        <i class="fas fa-key"></i> Force Reset Password
                    </button>
                    <a asp-action="Index" class="btn btn-secondary" style="margin-top: 1rem; padding: 0.875rem 2rem; border-radius: 10px;">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
