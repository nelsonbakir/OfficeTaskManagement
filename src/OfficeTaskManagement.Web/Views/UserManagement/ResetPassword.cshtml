@{
    ViewData["Title"] = "Reset Password";
    var userId = ViewBag.userId;
    var email = ViewBag.email;
}

<style>
    .delete-container {
        max-width: 600px;
        margin: 4rem auto;
        background: white;
        border: 1px solid #EDEBE9;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }
    
    .delete-header {
        background: #FDF3F4;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #FEE2E2;
        display: flex;
        align-items: center;
        gap: 1rem;
        color: #A4262C;
    }

    .delete-header.warning-header {
        background: #FFF4CE;
        border-bottom: 1px solid #FDE68A;
        color: #D18700;
    }
    
    .delete-header i {
        font-size: 2rem;
    }
    
    .delete-header h2 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 600;
    }
    
    .delete-body {
        padding: 2rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #252424;
        display: block;
        font-size: 0.9rem;
    }

    .form-control {
        border: 1px solid #EDEBE9;
        border-radius: 4px;
        padding: 0.625rem 0.875rem;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control:focus {
        border-color: #0078D4;
        box-shadow: 0 0 0 3px rgba(0, 120, 212, 0.1);
        outline: none;
    }

    .required-field::after {
        content: "*";
        color: #A4262C;
        margin-left: 0.25rem;
    }
    
    .delete-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #EDEBE9;
    }
</style>

<div class="delete-container">
    <div class="delete-header warning-header">
        <i class="fas fa-shield-alt"></i>
        <h2>Administrative Password Reset</h2>
    </div>
    
    <div class="delete-body">
        <p style="font-size: 1.1rem; color: #252424; margin-bottom: 1.5rem;">
            Resetting password for: <strong>@email</strong>
        </p>

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" name="id" value="@userId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-group">
                <label for="newPassword" class="form-label required-field">New Password</label>
                <input type="password" id="newPassword" name="newPassword" class="form-control" required />
                <small class="text-muted" style="font-size: 0.8rem; margin-top: 0.4rem; display: block;">
                    Minimum 6 characters, include uppercase, lowercase, and numbers.
                </small>
            </div>

            <div class="form-group mb-4">
                <label for="confirmPassword" class="form-label required-field">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" required />
            </div>

            <div class="alert alert-warning" style="background: #FFF4CE; border: 1px solid #FDE68A; color: #734C00;">
                <i class="fas fa-info-circle"></i> The user will be able to log in with the new password immediately.
            </div>

            <div class="delete-actions">
                <button type="submit" class="btn btn-warning px-4">
                    <i class="fas fa-key"></i> Force Reset Password
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
